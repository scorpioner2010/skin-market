<Project>
  <Target Name="CleanBuildCheckDirectories"
          BeforeTargets="PrepareForBuild"
          Condition="'$(OS)' == 'Windows_NT'">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)SkinMarket\scripts\clean-buildcheck.ps1&quot; -Root &quot;$(MSBuildProjectDirectory)&quot;" />
  </Target>
</Project>
