{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "App": {
    "DisableDatabase": false
  },
  "SteamBot": {
    "Enabled": false
  },
  "Pricing": {
    "PreferredCurrency": "USD",
    "EnableSteamSource": true,
    "EnableCsFloatSource": true,
    "EnableSkinportSource": true,
    "EnableDMarketSource": true,
    "EnableBitSkinsSource": false,
    "SteamCacheMinutes": 10,
    "CsFloatCacheMinutes": 10,
    "SkinportHistoryCacheMinutes": 10,
    "SkinportItemsCacheMinutes": 5,
    "SkinportOutOfStockCacheMinutes": 60,
    "DMarketLiveCacheMinutes": 5,
    "DMarketSalesHistoryCacheMinutes": 60,
    "SnapshotCacheHours": 24,
    "NegativeCacheMinutes": 5,
    "StaleSnapshotDays": 14,
    "StaleSnapshotHours": 24,
    "MaxConcurrentPriceLookups": 4,
    "AllowStaleSnapshotFallback": true,
    "SteamRetryCount": 2,
    "HttpTransientRetryDelayMilliseconds": 400,
    "RefreshTimeoutSeconds": 75,
    "RefreshingStateTimeoutSeconds": 90,
    "ConfidenceHighThreshold": 0.8,
    "ConfidenceMediumThreshold": 0.55,
    "EnablePriceProblemDiagnostics": true,
    "EnableVerbosePriceDiagnostics": false,
    "PriceDiagnosticsMemoryLimit": 2000,
    "PriceDiagnosticsFileEnabled": true,
    "PriceDiagnosticsDirectory": "logs/prices",
    "PriceDiagnosticsMaxLogsPerMinute": 100
  },
  "SteamMarketPrices": {
    "Enabled": true
  },
  "SteamInventoryRefresh": {
    "SnapshotFreshnessMinutes": 1,
    "AutoRefreshStaleMinutes": 2,
    "FailedAutoRefreshAttemptCooldownMinutes": 10,
    "DelayBetweenSteamRequestsSeconds": 3,
    "RequestTimeoutSeconds": 25,
    "FailedRefreshCooldownMinutes": 1
  }
}
