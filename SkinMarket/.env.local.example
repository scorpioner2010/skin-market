# Local developer environment for SkinMarket.
# Fill in the values you need and keep the real .env.local uncommitted.

# ASP.NET
ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://127.0.0.1:5271

# Database
# Leave App__DisableDatabase=true if you want degraded mode without PostgreSQL.
# Set App__DisableDatabase=false and fill either DATABASE_URL or ConnectionStrings__DefaultConnection for full local mode.
App__DisableDatabase=true
DATABASE_URL=
ConnectionStrings__DefaultConnection=

# Steam Web API
STEAM_API_KEY=

# Main app -> bot-service
STEAM_BOT_SERVICE_URL=http://127.0.0.1:5174
STEAM_BOT_SERVICE_PORT=5174
STEAM_BOT_POLL_INTERVAL_MS=60000
STEAM_BOT_MINIMUM_POLL_INTERVAL_MS=15000
STEAM_BOT_POLL_FULL_UPDATE_INTERVAL_MS=300000

# Steam bot account
# Set STEAM_BOT_ENABLED=true only after all bot fields below are filled.
STEAM_BOT_ENABLED=false
STEAM_BOT_USERNAME=
STEAM_BOT_PASSWORD=
STEAM_BOT_STEAM_ID=
STEAM_BOT_TRADE_URL=
STEAM_BOT_SHARED_SECRET=
STEAM_BOT_IDENTITY_SECRET=
