# Copy to /etc/xmania/xmania.env and fill values from Render or your VPS database.
# Do not commit real secrets.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://127.0.0.1:5000

# Database. Use one of these. DATABASE_URL can be a postgres:// URL or an Npgsql connection string.
DATABASE_URL=
ConnectionStrings__DefaultConnection=
App__DisableDatabase=false

# Steam Web API / OpenID support.
STEAM_API_KEY=
SteamApi__ApiKey=

# Cloudinary item images. CLOUDINARY_URL is also supported.
CLOUDINARY_URL=
Cloudinary__CloudName=
Cloudinary__ApiKey=
Cloudinary__ApiSecret=
Cloudinary__Folder=skin-market/items
Cloudinary__UploadPreset=

# ASP.NET app Steam bot integration.
STEAM_BOT_ENABLED=true
STEAM_BOT_AUTOSTART_LOCAL_SERVICE=false
STEAM_BOT_USERNAME=
STEAM_BOT_PASSWORD=
STEAM_BOT_STEAM_ID=
STEAM_BOT_TRADE_URL=
STEAM_BOT_SHARED_SECRET=
STEAM_BOT_IDENTITY_SECRET=
STEAM_BOT_SERVICE_URL=http://127.0.0.1:5174
SteamBot__Enabled=true
SteamBot__AutoStartLocalService=false
SteamBot__Username=
SteamBot__Password=
SteamBot__BotSteamId=
SteamBot__BotTradeUrl=
SteamBot__SharedSecret=
SteamBot__IdentitySecret=
SteamBot__ServiceUrl=http://127.0.0.1:5174

# Node bot-service. package.json is in bot-service/ and starts with: npm start.
# server.js listens on STEAM_BOT_SERVICE_PORT, default 5174.
STEAM_BOT_SERVICE_PORT=5174
STEAM_BOT_POLL_INTERVAL_MS=60000
STEAM_BOT_MINIMUM_POLL_INTERVAL_MS=15000
STEAM_BOT_POLL_FULL_UPDATE_INTERVAL_MS=300000

# Pricing and inventory workers.
SteamMarketPrices__Enabled=true
SteamInventoryRefresh__SnapshotFreshnessMinutes=1
SteamInventoryRefresh__AutoRefreshStaleMinutes=2
SteamInventoryRefresh__FailedAutoRefreshAttemptCooldownMinutes=10
SteamInventoryRefresh__DelayBetweenSteamRequestsSeconds=3
SteamInventoryRefresh__RequestTimeoutSeconds=25
SteamInventoryRefresh__FailedRefreshCooldownMinutes=1

Pricing__PreferredCurrency=USD
Pricing__EnableSteamSource=true
Pricing__EnableCsFloatSource=true
Pricing__EnableSkinportSource=true
Pricing__SteamCacheMinutes=10
Pricing__CsFloatCacheMinutes=10
Pricing__SkinportHistoryCacheMinutes=10
Pricing__SkinportItemsCacheMinutes=15
Pricing__SelectedPriceCacheHours=12
Pricing__SnapshotCacheHours=24
Pricing__NegativeCacheMinutes=5
Pricing__StaleSnapshotDays=14
Pricing__MaxConcurrentPriceLookups=4
Pricing__AllowStaleSnapshotFallback=true
Pricing__SteamRetryCount=2
Pricing__HttpTransientRetryDelayMilliseconds=400
Pricing__RefreshTimeoutSeconds=75
Pricing__RefreshingStateTimeoutSeconds=90

AllowedHosts=*
