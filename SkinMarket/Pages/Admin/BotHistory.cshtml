@page
@model SkinMarket.Pages.Admin.BotHistoryModel
@{
    ViewData["Title"] = "Bot History";
    string BuildSteamOfferUrl(string? offerId) => string.IsNullOrWhiteSpace(offerId)
        ? "https://steamcommunity.com/my/tradeoffers/"
        : $"https://steamcommunity.com/tradeoffer/{offerId}/";
    string BuildSteamProfileUrl(string? steamId) => string.IsNullOrWhiteSpace(steamId)
        ? "https://steamcommunity.com/"
        : $"https://steamcommunity.com/profiles/{steamId}/";
    string FormatLocalDateTime(DateTime? timestamp, string fallback = "Never") => timestamp?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? fallback;
    var historyMode = string.IsNullOrWhiteSpace(Model.HistoryMode) ? "all" : Model.HistoryMode;
}

<div class="py-4">
    <div class="page-header">
        <div>
            <h1>Bot History</h1>
            <p class="text-muted mb-0">Bot purchase and sale history.</p>
        </div>
        <div class="action-row">
            <a class="btn app-button-secondary" asp-page="/Admin/BotStatus">Bot Status</a>
            <a class="btn app-button-primary"
               asp-page="/Admin/BotHistory"
               asp-route-limit="@Model.Limit"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-historyMode="@(historyMode == "all" ? null : historyMode)">Bot History</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Logs">Logs</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Accounts">Accounts</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Items">Items</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Games">Games</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Chats">Chats</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert alert-warning" role="alert">@Model.ErrorMessage</div>
    }

    <section class="page-section history-tabs" data-admin-bot-history-tabs>
        <div class="history-tab-list" role="tablist" aria-label="Bot history">
            <button type="button" class="history-tab-button active" role="tab" aria-selected="true" data-admin-bot-history-tab="purchases">Bot purchases</button>
            <button type="button" class="history-tab-button" role="tab" aria-selected="false" data-admin-bot-history-tab="sales">Bot sales</button>
        </div>

        <div class="history-tab-panel" data-admin-bot-history-panel="purchases">
            @if (Model.PurchaseHistory.Count == 0)
            {
                <div class="empty-state compact">
                    <h3>No bot purchase history yet.</h3>
                </div>
            }
            else
            {
                <div class="market-table-shell admin-table-shell admin-bot-history-shell">
                    <div class="market-table-list admin-bot-purchases-table">
                        <div class="market-table-row market-table-header admin-bot-history-row">
                            <div class="market-table-cell market-table-item-cell">Item</div>
                            <div class="market-table-cell">Seller</div>
                            <div class="market-table-cell">Status</div>
                            <div class="market-table-cell">Credit</div>
                            <div class="market-table-cell market-table-actions-cell">Links</div>
                        </div>
                        @foreach (var item in Model.PurchaseHistory)
                        {
                            <div class="market-table-row admin-bot-history-row">
                                <div class="market-table-cell market-table-item-cell" data-label="Item">
                                    <div class="market-table-copy">
                                        <div class="history-item-title">@item.ItemName</div>
                                        <div class="card-subtitle break-value">@item.AssetId</div>
                                    </div>
                                </div>
                                <div class="market-table-cell" data-label="Seller">
                                    <div class="market-table-copy">
                                        <div>@item.SellerDisplayName</div>
                                        <div class="card-subtitle break-value">@item.SellerSteamId</div>
                                    </div>
                                </div>
                                <div class="market-table-cell" data-label="Status">
                                    <span class="status-badge" data-status="@item.Status">@item.Status</span>
                                </div>
                                <div class="market-table-cell" data-label="Credit">
                                    <div class="market-table-copy">
                                        <div>@item.CreditAmount</div>
                                        <div class="card-subtitle">Credited: @FormatLocalDateTime(item.CreditedAtUtc)</div>
                                    </div>
                                </div>
                                <div class="market-table-cell market-table-actions-cell admin-bot-history-actions" data-label="Links">
                                    @if (Model.CanOpenSellerOffer(item))
                                    {
                                        <a class="btn app-button-primary" href="@BuildSteamOfferUrl(item.TradeOfferId)" target="_blank" rel="noopener">
                                            @(item.Status == "AwaitingUserAction" ? "Open offer" : "Offer")
                                        </a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(item.SellerSteamId))
                                    {
                                        <a class="btn app-button-secondary" href="@BuildSteamProfileUrl(item.SellerSteamId)" target="_blank" rel="noopener">Seller Steam</a>
                                    }
                                    @if (!Model.CanOpenSellerOffer(item) && string.IsNullOrWhiteSpace(item.SellerSteamId))
                                    {
                                        <span class="compact-badge compact-badge-neutral">No links</span>
                                    }
                                </div>
                                <div class="market-table-cell admin-bot-history-meta" data-label="Details">
                                    <span><strong>Created:</strong> @FormatLocalDateTime(item.CreatedAtUtc, "Unknown")</span>
                                    <span><strong>Received:</strong> @FormatLocalDateTime(item.ReceivedByBotAtUtc)</span>
                                    <span><strong>Updated:</strong> @FormatLocalDateTime(item.UpdatedAtUtc, "Unknown")</span>
                                    <span><strong>Trade offer:</strong> <span class="break-value">@(item.TradeOfferId ?? "None")</span></span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.ErrorMessage))
                                {
                                    <div class="history-row-note">@item.ErrorMessage</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="history-tab-panel" data-admin-bot-history-panel="sales" hidden>
            @if (Model.SaleHistory.Count == 0)
            {
                <div class="empty-state compact">
                    <h3>No bot sale history yet.</h3>
                </div>
            }
            else
            {
                <div class="market-table-shell admin-table-shell admin-bot-history-shell">
                    <div class="market-table-list admin-bot-sales-table">
                        <div class="market-table-row market-table-header admin-bot-history-row">
                            <div class="market-table-cell market-table-item-cell">Item</div>
                            <div class="market-table-cell">Buyer</div>
                            <div class="market-table-cell">Status</div>
                            <div class="market-table-cell">Price</div>
                            <div class="market-table-cell market-table-actions-cell">Links</div>
                        </div>
                        @foreach (var item in Model.SaleHistory)
                        {
                            <div class="market-table-row admin-bot-history-row">
                                <div class="market-table-cell market-table-item-cell" data-label="Item">
                                    <div class="market-table-copy">
                                        <div class="history-item-title">@item.ItemName</div>
                                        <div class="card-subtitle break-value">@item.AssetId</div>
                                        @if (!string.IsNullOrWhiteSpace(item.SourceSellerDisplayName))
                                        {
                                            <div class="card-subtitle">Source: @item.SourceSellerDisplayName</div>
                                        }
                                    </div>
                                </div>
                                <div class="market-table-cell" data-label="Buyer">
                                    <div class="market-table-copy">
                                        <div>@item.BuyerDisplayName</div>
                                        <div class="card-subtitle break-value">@item.BuyerSteamId</div>
                                    </div>
                                </div>
                                <div class="market-table-cell status-group" data-label="Status">
                                    <span class="status-badge" data-status="@item.Status">@item.Status</span>
                                    @if (!string.IsNullOrWhiteSpace(item.DeliveryStatus))
                                    {
                                        <span class="status-badge" data-status="@item.DeliveryStatus">@item.DeliveryStatus</span>
                                    }
                                </div>
                                <div class="market-table-cell" data-label="Price">
                                    <span>@item.Price</span>
                                </div>
                                <div class="market-table-cell market-table-actions-cell admin-bot-history-actions" data-label="Links">
                                    @if (!string.IsNullOrWhiteSpace(item.BuyerSteamId))
                                    {
                                        <a class="btn app-button-secondary" href="@BuildSteamProfileUrl(item.BuyerSteamId)" target="_blank" rel="noopener">Buyer Steam</a>
                                    }
                                    <a class="btn app-button-secondary" href="https://steamcommunity.com/my/tradeoffers/" target="_blank" rel="noopener">Open Steam offers</a>
                                    <a class="btn app-button-secondary" asp-page="/Market">Open local Market</a>
                                    @if (Model.CanOpenBuyerOffer(item))
                                    {
                                        <a class="btn app-button-primary" href="@BuildSteamOfferUrl(item.DeliveryTradeOfferId)" target="_blank" rel="noopener">
                                            @(item.DeliveryStatus == "AwaitingBuyerAction" ? "Accept or decline buyer offer" : "Open exact buyer offer")
                                        </a>
                                    }
                                    @if (string.IsNullOrWhiteSpace(item.BuyerSteamId) && !Model.CanOpenBuyerOffer(item))
                                    {
                                        <span class="compact-badge compact-badge-neutral">No links</span>
                                    }
                                </div>
                                <div class="market-table-cell admin-bot-history-meta" data-label="Details">
                                    <span><strong>Created:</strong> @FormatLocalDateTime(item.CreatedAtUtc, "Unknown")</span>
                                    <span><strong>Purchased:</strong> @FormatLocalDateTime(item.PurchasedAtUtc)</span>
                                    <span><strong>Updated:</strong> @FormatLocalDateTime(item.UpdatedAtUtc, "Unknown")</span>
                                    <span><strong>Delivered:</strong> @FormatLocalDateTime(item.DeliveredAtUtc)</span>
                                    <span><strong>Trade offer:</strong> <span class="break-value">@(item.DeliveryTradeOfferId ?? "None")</span></span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.DeliveryErrorMessage))
                                {
                                    <div class="history-row-note">@item.DeliveryErrorMessage</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>
</div>

@section Scripts {
    <script>
        (() => {
            const root = document.querySelector('[data-admin-bot-history-tabs]');
            if (!root) {
                return;
            }

            const tabs = Array.from(root.querySelectorAll('[data-admin-bot-history-tab]'));
            const panels = Array.from(root.querySelectorAll('[data-admin-bot-history-panel]'));
            const storageKey = 'skinmarket-admin-bot-history-tab';

            const activate = (target) => {
                if (!tabs.some((tab) => tab.dataset.adminBotHistoryTab === target)) {
                    return;
                }

                tabs.forEach((candidate) => {
                    const isActive = candidate.dataset.adminBotHistoryTab === target;
                    candidate.classList.toggle('active', isActive);
                    candidate.setAttribute('aria-selected', isActive ? 'true' : 'false');
                });

                panels.forEach((panel) => {
                    panel.hidden = panel.dataset.adminBotHistoryPanel !== target;
                });
            };

            activate(localStorage.getItem(storageKey) || 'purchases');

            tabs.forEach((tab) => {
                tab.addEventListener('click', () => {
                    const target = tab.dataset.adminBotHistoryTab;
                    localStorage.setItem(storageKey, target);
                    activate(target);
                });
            });
        })();
    </script>
}
