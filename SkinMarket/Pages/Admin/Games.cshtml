@page
@model SkinMarket.Pages.Admin.GamesModel
@{
    ViewData["Title"] = "Admin Games";
}

<div class="admin-games-page py-4">
    <div class="page-header">
        <div>
            <h1>Games</h1>
            <p class="text-muted mb-0">Prepare and manage Unity WebGL game integrations.</p>
        </div>
        <div class="action-row">
            <a class="btn app-button-secondary" asp-page="/Admin/BotStatus">Bot Status</a>
            <a class="btn app-button-secondary" asp-page="/Admin/BotHistory">Bot History</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Logs">Logs</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Accounts">Accounts</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Items">Items</a>
            <a class="btn app-button-primary" asp-page="/Admin/Games">Games</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Chats">Chats</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="app-alert alert-success" role="alert">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <section class="page-section admin-games-shell">
        <div class="content-card">
            <div class="card-heading">
                <div>
                    <h2>Game list</h2>
                    <p class="card-subtitle">@Model.Games.Count game(s) configured.</p>
                </div>
            </div>

            @if (Model.Games.Count == 0)
            {
                <div class="empty-state compact">
                    <h3>No games configured yet.</h3>
                    <p class="text-muted mb-0">Future Unity WebGL games will be selectable from this list.</p>
                </div>
            }
            else
            {
                <div class="market-table-shell admin-table-shell admin-games-table-shell">
                    <div class="market-table-list admin-games-table">
                        <div class="market-table-row market-table-header admin-games-row">
                            <div class="market-table-cell market-table-item-cell">Game</div>
                            <div class="market-table-cell">Status</div>
                            <div class="market-table-cell market-table-actions-cell">Actions</div>
                        </div>
                        @foreach (var game in Model.Games)
                        {
                            <article class="market-table-row admin-games-row">
                                <div class="market-table-cell market-table-item-cell" data-label="Game">
                                    <div class="market-table-copy admin-game-main">
                                        <strong>@game.Name</strong>
                                        <div class="inventory-meta break-value">@game.Key</div>
                                    </div>
                                </div>
                                <div class="market-table-cell" data-label="Status">
                                    <span class="compact-badge">@game.Status</span>
                                </div>
                                <div class="market-table-cell market-table-actions-cell" data-label="Actions">
                                    <a class="btn app-button-secondary market-table-action-button" asp-page="/Admin/Games" asp-route-gameKey="@game.Key">Settings</a>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="content-card">
            <div class="card-heading">
                <div>
                    <h2>Game settings</h2>
                    <p class="card-subtitle">Select a game to edit its admin settings.</p>
                </div>
            </div>

            @if (Model.SelectedGame is null)
            {
                <div class="empty-state compact">
                    <h3>No game selected.</h3>
                    <p class="text-muted mb-0">Settings controls will be shown here when games are added.</p>
                </div>
            }
            else if (Model.SelectedGame.Key != "minefield")
            {
                <div class="empty-state compact">
                    <h3>@Model.SelectedGame.Name</h3>
                    <p class="text-muted mb-0">This game does not have custom admin settings yet.</p>
                </div>
            }

            @if (Model.SelectedGame?.Key == "minefield")
            {
                <form method="post" asp-page-handler="SaveMinefield" asp-route-gameKey="@Model.SelectedGame.Key" class="stack-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-check">
                        <input class="form-check-input" asp-for="MinefieldInput.IsEnabled" />
                        <label class="form-check-label" asp-for="MinefieldInput.IsEnabled">Game enabled</label>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" asp-for="MinefieldInput.MinimumBet">Minimum bet</label>
                            <input class="form-control app-input" asp-for="MinefieldInput.MinimumBet" type="number" min="0.01" max="1000000" step="0.01" />
                            <span class="text-danger" asp-validation-for="MinefieldInput.MinimumBet"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="MinefieldInput.MaximumBet">Maximum bet</label>
                            <input class="form-control app-input" asp-for="MinefieldInput.MaximumBet" type="number" min="0.01" max="1000000" step="0.01" />
                            <span class="text-danger" asp-validation-for="MinefieldInput.MaximumBet"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="MinefieldInput.MinesPerLine">Mines per line</label>
                            <input class="form-control app-input" asp-for="MinefieldInput.MinesPerLine" type="number" min="1" max="4" step="1" />
                            <span class="text-danger" asp-validation-for="MinefieldInput.MinesPerLine"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="MinefieldInput.ReturnToPlayerPercent">RTP (%)</label>
                            <input class="form-control app-input" asp-for="MinefieldInput.ReturnToPlayerPercent" type="number" min="1" max="100" step="0.01" />
                            <span class="text-danger" asp-validation-for="MinefieldInput.ReturnToPlayerPercent"></span>
                        </div>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" asp-for="MinefieldInput.UseCustomStepSafeChances" />
                        <label class="form-check-label" asp-for="MinefieldInput.UseCustomStepSafeChances">Use custom safe chance per step</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" asp-for="MinefieldInput.UseCustomStepMultipliers" />
                        <label class="form-check-label" asp-for="MinefieldInput.UseCustomStepMultipliers">Use custom multiplier per step</label>
                    </div>

                    <div class="meta-note">
                        Field size is fixed at 10 rows x 5 columns for the current Unity build. Multipliers are generated from RTP and the active safe chances unless custom multipliers are enabled.
                    </div>

                    <div class="market-table-shell admin-table-shell">
                        <div class="market-table-list admin-minefield-steps-table">
                            <div class="market-table-row market-table-header admin-minefield-step-row">
                                <div class="market-table-cell">Step</div>
                                <div class="market-table-cell">Safe chance (%)</div>
                                <div class="market-table-cell">Mine chance</div>
                                <div class="market-table-cell">Multiplier</div>
                                <div class="market-table-cell">Active multiplier</div>
                            </div>
                            @for (var i = 0; i < Model.MinefieldInput.StepSafeChancePercents.Count; i++)
                            {
                                var preview = i < Model.MinefieldStepPreview.Count ? Model.MinefieldStepPreview[i] : null;
                                <article class="market-table-row admin-minefield-step-row">
                                    <div class="market-table-cell" data-label="Step">@(i + 1)</div>
                                    <div class="market-table-cell" data-label="Safe chance (%)">
                                        <input class="form-control app-input" asp-for="MinefieldInput.StepSafeChancePercents[i]" type="number" min="1" max="100" step="0.01" />
                                        <span class="text-danger" asp-validation-for="MinefieldInput.StepSafeChancePercents[i]"></span>
                                    </div>
                                    <div class="market-table-cell" data-label="Mine chance">
                                        @(preview?.MineChancePercent.ToString("0.##") ?? "0")%
                                    </div>
                                    <div class="market-table-cell" data-label="Multiplier">
                                        <input class="form-control app-input" asp-for="MinefieldInput.StepMultipliers[i]" type="number" min="0.1" max="1000000" step="0.1" />
                                        <span class="text-danger" asp-validation-for="MinefieldInput.StepMultipliers[i]"></span>
                                    </div>
                                    <div class="market-table-cell" data-label="Active multiplier">
                                        x@(preview?.Multiplier.ToString("0.####") ?? "0.0")
                                    </div>
                                </article>
                            }
                        </div>
                    </div>

                    <button type="submit" class="btn app-button-primary">Save Minefield settings</button>
                </form>
            }
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
