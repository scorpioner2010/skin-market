@page
@model SkinMarket.Pages.Admin.LogsModel
@{
    ViewData["Title"] = "Bot Logs";
    var recentBotIssues = Model.BotStatus.Bot.RecentIssues ?? new List<SkinMarket.Models.BotServiceIssueSnapshot>();
    var take = Model.Limit <= 0 ? 100 : Math.Min(Model.Limit, 500);
}

<div class="py-4">
    <div class="page-header">
        <div>
            <h1>Bot Logs</h1>
            <p class="text-muted mb-0">Bot-service issues, Steam inventory diagnostics, app-side failures, and workflow history.</p>
        </div>
        <div class="action-row">
            <a class="btn app-button-secondary" asp-page="/Admin/BotStatus">Bot Status</a>
            <a class="btn app-button-secondary" asp-page="/Admin/BotHistory">Bot History</a>
            <a class="btn app-button-secondary" asp-page="/Admin/BotLogs">Steam Trade Bot Logs</a>
            <a class="btn app-button-secondary" asp-page="/Admin/PriceDiagnostics">Price Diagnostics</a>
            <a class="btn app-button-primary" asp-page="/Admin/Logs">Logs</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Accounts">Accounts</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Items">Items</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Games">Games</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Menus">Menus</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Chats">Chats</a>
        </div>
    </div>

    <div class="content-card mb-4">
        <div class="card-heading">
            <h2>Service Snapshot</h2>
            <span class="status-badge" data-status="@(!Model.BotStatus.Reachable ? "Failed" : Model.BotStatus.IsActive ? "Credited" : "Pending")">
                @(!Model.BotStatus.Reachable ? "Unavailable" : Model.BotStatus.Bot.ServiceState ?? "Unknown")
            </span>
        </div>
        <div class="history-metrics">
            <span><strong>Reachable:</strong> @(Model.BotStatus.Reachable ? "Yes" : "No")</span>
            <span><strong>Ready:</strong> @(Model.BotStatus.Bot.Ready ? "Yes" : "No")</span>
            <span><strong>Logged On:</strong> @(Model.BotStatus.Bot.LoggedOn ? "Yes" : "No")</span>
            <span><strong>Active Work:</strong> @Model.BotStatus.Bot.ActiveActivityCount</span>
            <span><strong>Last Error:</strong> @(string.IsNullOrWhiteSpace(Model.BotStatus.Bot.LastError) ? "None" : Model.BotStatus.Bot.LastError)</span>
        </div>
        @if (!Model.BotStatus.Reachable && !string.IsNullOrWhiteSpace(Model.BotStatus.ReachabilityError))
        {
            <div class="meta-note mt-3">@Model.BotStatus.ReachabilityError</div>
        }
    </div>

    <section class="page-section">
        <div class="section-heading">
            <div>
                <h2>Log Center</h2>
                <p class="section-description">Use the buttons below to switch between log groups.</p>
            </div>
            <form method="get" class="action-row">
                <select name="Limit" class="form-select app-input" style="max-width: 120px;">
                    <option value="100" selected="@(Model.Limit != 250 && Model.Limit != 500)">100</option>
                    <option value="250" selected="@(Model.Limit == 250)">250</option>
                    <option value="500" selected="@(Model.Limit == 500)">500</option>
                </select>
                <button type="submit" class="btn app-button-secondary">Apply</button>
            </form>
        </div>

        <div class="history-tabs" data-admin-log-tabs>
            <div class="history-tab-list" role="tablist" aria-label="Log sections">
                <button type="button" class="history-tab-button active" role="tab" aria-selected="true" data-admin-log-tab="bot-service">bot-service Issues (@Math.Min(recentBotIssues.Count, take))</button>
                <a class="history-tab-button" role="tab" aria-selected="false" asp-page="/Admin/BotLogs">Steam Trade Bot Logs</a>
                <button type="button" class="history-tab-button" role="tab" aria-selected="false" data-admin-log-tab="steam-inventory">Steam Inventory (@Model.InventoryEntries.Count)</button>
                <button type="button" class="history-tab-button" role="tab" aria-selected="false" data-admin-log-tab="application">Application Issues (@Model.AppEntries.Count)</button>
                <button type="button" class="history-tab-button" role="tab" aria-selected="false" data-admin-log-tab="workflow">Workflow Logs (@Model.WorkflowEntries.Count)</button>
            </div>

            <div class="history-tab-panel" data-admin-log-panel="bot-service">
                <div class="section-heading">
                    <div><h2>bot-service Issues</h2></div>
                </div>

                @if (recentBotIssues.Count == 0)
                {
                    <div class="empty-state compact">
                        <h3>No current bot-service issues.</h3>
                    </div>
                }
                else
                {
                    <div class="market-table-shell admin-table-shell admin-log-shell">
                        <div class="market-table-list admin-log-table">
                            <div class="market-table-row market-table-header admin-log-row">
                                <div class="market-table-cell market-table-item-cell">Issue</div>
                                <div class="market-table-cell">Level</div>
                                <div class="market-table-cell">Time</div>
                                <div class="market-table-cell">Details</div>
                            </div>
                        @foreach (var issue in recentBotIssues.Take(take))
                        {
                            <article class="market-table-row admin-log-row">
                                <div class="market-table-cell market-table-item-cell" data-label="Issue">
                                    <div class="market-table-copy">
                                        <strong>@issue.Message</strong>
                                        <div class="card-subtitle">bot-service</div>
                                    </div>
                                </div>
                                <div class="market-table-cell" data-label="Level">
                                    <span class="status-badge" data-status="@(string.Equals(issue.Level, "Error", StringComparison.OrdinalIgnoreCase) ? "Failed" : "Pending")">@issue.Level</span>
                                </div>
                                <div class="market-table-cell" data-label="Time">
                                    <span>@(issue.Timestamp?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz") ?? "Unknown")</span>
                                </div>
                                <div class="market-table-cell admin-log-details" data-label="Details">
                                    @foreach (var detail in issue.Details)
                                    {
                                        <span><strong>@detail.Key:</strong> <span class="break-value">@detail.Value</span></span>
                                    }
                                </div>
                            </article>
                        }
                        </div>
                    </div>
                }
            </div>

            <div class="history-tab-panel" data-admin-log-panel="steam-inventory" hidden>
                <div class="section-heading">
                    <div>
                        <h2>Steam Inventory Diagnostics</h2>
                        <p class="section-description">Recent inventory page, Steam community endpoint, bot fallback, 429, cooldown, and incomplete-payload entries.</p>
                    </div>
                </div>

                <div class="content-card mb-4">
                    <div class="card-heading">
                        <div>
                            <h3>Hosting Context</h3>
                            <p class="card-subtitle">Useful when the issue appears on Render but not locally.</p>
                        </div>
                    </div>
                    <div class="history-metrics">
                        @foreach (var detail in Model.HostingDetails)
                        {
                            <span><strong>@detail.Key:</strong> <span class="break-value">@detail.Value</span></span>
                        }
                    </div>
                </div>

                <div class="content-card mb-4" data-steam-inventory-server-test>
                    <div class="card-heading">
                        <div>
                            <h3>Steam Inventory Server Test</h3>
                            <p class="card-subtitle">Runs one inventory request from this server and one outbound IP lookup. It does not update snapshots or cooldowns.</p>
                        </div>
                    </div>
                    <div class="history-metrics">
                        <label>
                            <strong>SteamId</strong>
                            <input class="form-control app-input" data-test-steamid value="@Model.CurrentSteamId" />
                        </label>
                        <label>
                            <strong>Game</strong>
                            <select class="form-select app-input" data-test-game>
                                @foreach (var game in Model.SupportedInventoryGames)
                                {
                                    <option value="@((int)game.Type)">@game.ShortName (@game.SteamAppId/@game.SteamContextId)</option>
                                }
                            </select>
                        </label>
                        <button type="button" class="btn app-button-secondary" data-test-button>Test Steam Inventory From Server</button>
                    </div>
                    <pre class="meta-note mt-3 mb-0" data-test-result hidden></pre>
                </div>

                @if (Model.InventoryEntries.Count == 0)
                {
                    <div class="empty-state compact">
                        <h3>No Steam inventory diagnostic entries yet.</h3>
                    </div>
                }
                else
                {
                    <div class="market-table-shell admin-table-shell admin-log-shell">
                        <div class="market-table-list admin-log-table">
                            <div class="market-table-row market-table-header admin-log-row">
                                <div class="market-table-cell market-table-item-cell">Entry</div>
                                <div class="market-table-cell">Level</div>
                                <div class="market-table-cell">Time</div>
                                <div class="market-table-cell">Details</div>
                            </div>
                        @foreach (var entry in Model.InventoryEntries)
                        {
                            <article class="market-table-row admin-log-row">
                                <div class="market-table-cell market-table-item-cell" data-label="Entry">
                                    <div class="market-table-copy">
                                        <strong>@entry.Message</strong>
                                        <div class="card-subtitle">@entry.Source</div>
                                    </div>
                                </div>
                                <div class="market-table-cell" data-label="Level">
                                    <span class="status-badge" data-status="@(string.Equals(entry.Level, "Error", StringComparison.OrdinalIgnoreCase) ? "Failed" : string.Equals(entry.Level, "Warning", StringComparison.OrdinalIgnoreCase) ? "Pending" : "Credited")">@entry.Level</span>
                                </div>
                                <div class="market-table-cell" data-label="Time">
                                    <span>@entry.TimestampUtc.ToLocalTime()</span>
                                </div>
                                <div class="market-table-cell admin-log-details" data-label="Details">
                                    @if (!string.IsNullOrWhiteSpace(entry.StackTrace))
                                    {
                                        <details class="admin-log-stack">
                                            <summary>Stack trace</summary>
                                            <pre class="meta-note mb-0">@entry.StackTrace</pre>
                                        </details>
                                    }
                                    else
                                    {
                                        <span class="compact-badge compact-badge-neutral">No stack trace</span>
                                    }
                                </div>
                            </article>
                        }
                        </div>
                    </div>
                }
            </div>

            <div class="history-tab-panel" data-admin-log-panel="application" hidden>
                <div class="section-heading">
                    <div><h2>Application Issues</h2></div>
                </div>

                @if (Model.AppEntries.Count == 0)
                {
                    <div class="empty-state compact">
                        <h3>No app-side bot issues recorded.</h3>
                    </div>
                }
                else
                {
                    <div class="market-table-shell admin-table-shell admin-log-shell">
                        <div class="market-table-list admin-log-table">
                            <div class="market-table-row market-table-header admin-log-row">
                                <div class="market-table-cell market-table-item-cell">Issue</div>
                                <div class="market-table-cell">Level</div>
                                <div class="market-table-cell">Time</div>
                                <div class="market-table-cell">Details</div>
                            </div>
                        @foreach (var entry in Model.AppEntries)
                        {
                            <article class="market-table-row admin-log-row">
                                <div class="market-table-cell market-table-item-cell" data-label="Issue">
                                    <div class="market-table-copy">
                                        <strong>@entry.Message</strong>
                                        <div class="card-subtitle">@entry.Source</div>
                                    </div>
                                </div>
                                <div class="market-table-cell" data-label="Level">
                                    <span class="status-badge" data-status="@(string.Equals(entry.Level, "Error", StringComparison.OrdinalIgnoreCase) ? "Failed" : "Pending")">@entry.Level</span>
                                </div>
                                <div class="market-table-cell" data-label="Time">
                                    <span>@entry.TimestampUtc.ToLocalTime()</span>
                                </div>
                                <div class="market-table-cell admin-log-details" data-label="Details">
                                    @if (!string.IsNullOrWhiteSpace(entry.StackTrace))
                                    {
                                        <details class="admin-log-stack">
                                            <summary>Stack trace</summary>
                                            <pre class="meta-note mb-0">@entry.StackTrace</pre>
                                        </details>
                                    }
                                    else
                                    {
                                        <span class="compact-badge compact-badge-neutral">No stack trace</span>
                                    }
                                </div>
                            </article>
                        }
                        </div>
                    </div>
                }
            </div>

            <div class="history-tab-panel" data-admin-log-panel="workflow" hidden>
                <div class="section-heading">
                    <div>
                        <h2>Workflow Logs</h2>
                        <p class="section-description">Info, warning, and error entries for sell, credit, buy, delivery, sync, and recovery actions.</p>
                    </div>
                </div>

                @if (Model.WorkflowEntries.Count == 0)
                {
                    <div class="empty-state compact">
                        <h3>No workflow log entries yet.</h3>
                    </div>
                }
                else
                {
                    <div class="market-table-shell admin-table-shell admin-log-shell">
                        <div class="market-table-list admin-log-table">
                            <div class="market-table-row market-table-header admin-log-row">
                                <div class="market-table-cell market-table-item-cell">Entry</div>
                                <div class="market-table-cell">Level</div>
                                <div class="market-table-cell">Time</div>
                                <div class="market-table-cell">Details</div>
                            </div>
                        @foreach (var entry in Model.WorkflowEntries.Take(take))
                        {
                            <article class="market-table-row admin-log-row">
                                <div class="market-table-cell market-table-item-cell" data-label="Entry">
                                    <div class="market-table-copy">
                                        <strong>@entry.Message</strong>
                                        <div class="card-subtitle">@entry.Source</div>
                                    </div>
                                </div>
                                <div class="market-table-cell" data-label="Level">
                                    <span class="status-badge" data-status="@(string.Equals(entry.Level, "Error", StringComparison.OrdinalIgnoreCase) ? "Failed" : string.Equals(entry.Level, "Warning", StringComparison.OrdinalIgnoreCase) ? "Pending" : "Credited")">@entry.Level</span>
                                </div>
                                <div class="market-table-cell" data-label="Time">
                                    <span>@entry.TimestampUtc.ToLocalTime()</span>
                                </div>
                                <div class="market-table-cell admin-log-details" data-label="Details">
                                    @if (!string.IsNullOrWhiteSpace(entry.StackTrace))
                                    {
                                        <details class="admin-log-stack">
                                            <summary>Stack trace</summary>
                                            <pre class="meta-note mb-0">@entry.StackTrace</pre>
                                        </details>
                                    }
                                    else
                                    {
                                        <span class="compact-badge compact-badge-neutral">No stack trace</span>
                                    }
                                </div>
                            </article>
                        }
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        (() => {
            const root = document.querySelector('[data-steam-inventory-server-test]');
            if (!root) {
                return;
            }

            const button = root.querySelector('[data-test-button]');
            const result = root.querySelector('[data-test-result]');
            const steamIdInput = root.querySelector('[data-test-steamid]');
            const gameInput = root.querySelector('[data-test-game]');

            button?.addEventListener('click', async () => {
                if (!result) {
                    return;
                }

                button.disabled = true;
                result.hidden = false;
                result.textContent = 'Running Steam inventory diagnostic...';
                try {
                    const response = await fetch('/api/admin/steam-inventory/test', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            steamId: steamIdInput?.value || '',
                            gameType: Number(gameInput?.value || 1)
                        })
                    });

                    const payload = await response.json();
                    result.textContent = JSON.stringify(payload, null, 2);
                } catch (error) {
                    result.textContent = `Diagnostic failed: ${error}`;
                } finally {
                    button.disabled = false;
                }
            });
        })();

        (() => {
            const root = document.querySelector('[data-admin-log-tabs]');
            if (!root) {
                return;
            }

            const tabs = Array.from(root.querySelectorAll('[data-admin-log-tab]'));
            const panels = Array.from(root.querySelectorAll('[data-admin-log-panel]'));
            const storageKey = 'skinmarket-admin-log-tab';

            const activate = (target) => {
                if (!tabs.some((tab) => tab.dataset.adminLogTab === target)) {
                    return;
                }

                tabs.forEach((candidate) => {
                    const isActive = candidate.dataset.adminLogTab === target;
                    candidate.classList.toggle('active', isActive);
                    candidate.setAttribute('aria-selected', isActive ? 'true' : 'false');
                });

                panels.forEach((panel) => {
                    panel.hidden = panel.dataset.adminLogPanel !== target;
                });
            };

            activate(localStorage.getItem(storageKey) || 'bot-service');

            tabs.forEach((tab) => {
                tab.addEventListener('click', () => {
                    const target = tab.dataset.adminLogTab;
                    localStorage.setItem(storageKey, target);
                    activate(target);
                });
            });
        })();
    </script>
}
