@page
@model SkinMarket.Pages.Admin.LogsModel
@{
    ViewData["Title"] = "Bot Logs";
    var recentBotIssues = Model.BotStatus.Bot.RecentIssues ?? new List<SkinMarket.Models.BotServiceIssueSnapshot>();
    var take = Model.Limit <= 0 ? 50 : Math.Min(Model.Limit, 200);
}

<div class="py-4">
    <div class="page-header">
        <div>
            <h1>Bot Logs</h1>
            <p class="text-muted mb-0">Bot-service issues, app-side failures, and workflow history live here instead of taking space on the status page.</p>
        </div>
        <div class="action-row">
            <a class="btn app-button-secondary" asp-page="/Admin/BotStatus">Bot Status</a>
            <a class="btn app-button-secondary" asp-page="/Admin/BotHistory">Bot History</a>
            <a class="btn app-button-primary" asp-page="/Admin/Logs">Logs</a>
        </div>
    </div>

    <div class="content-card mb-4">
        <div class="card-heading">
            <h2>Service Snapshot</h2>
            <span class="status-badge" data-status="@(!Model.BotStatus.Reachable ? "Failed" : Model.BotStatus.IsActive ? "Credited" : "Pending")">
                @(!Model.BotStatus.Reachable ? "Unavailable" : Model.BotStatus.Bot.ServiceState ?? "Unknown")
            </span>
        </div>
        <div class="history-metrics">
            <span><strong>Reachable:</strong> @(Model.BotStatus.Reachable ? "Yes" : "No")</span>
            <span><strong>Ready:</strong> @(Model.BotStatus.Bot.Ready ? "Yes" : "No")</span>
            <span><strong>Logged On:</strong> @(Model.BotStatus.Bot.LoggedOn ? "Yes" : "No")</span>
            <span><strong>Active Work:</strong> @Model.BotStatus.Bot.ActiveActivityCount</span>
            <span><strong>Last Error:</strong> @(string.IsNullOrWhiteSpace(Model.BotStatus.Bot.LastError) ? "None" : Model.BotStatus.Bot.LastError)</span>
        </div>
        @if (!Model.BotStatus.Reachable && !string.IsNullOrWhiteSpace(Model.BotStatus.ReachabilityError))
        {
            <div class="meta-note mt-3">@Model.BotStatus.ReachabilityError</div>
        }
    </div>

    <section class="page-section">
        <div class="section-heading">
            <div>
                <h2>Log Center</h2>
                <p class="section-description">Use one place for service issues, application exceptions, and workflow history.</p>
            </div>
            <form method="get" class="action-row">
                <select name="Limit" class="form-select app-input" style="max-width: 120px;">
                    <option value="25" selected="@(Model.Limit == 25)">25</option>
                    <option value="50" selected="@(Model.Limit != 25 && Model.Limit != 100)">50</option>
                    <option value="100" selected="@(Model.Limit == 100)">100</option>
                </select>
                <button type="submit" class="btn app-button-secondary">Apply</button>
            </form>
        </div>

        <div class="card-grid">
            <article class="content-card live-status-card">
                <span class="section-kicker">bot-service</span>
                <div class="card-heading">
                    <h3>Current Issues</h3>
                    <span class="compact-badge compact-badge-neutral">@Math.Min(recentBotIssues.Count, take)</span>
                </div>
                <p class="card-subtitle">Warnings and errors reported directly by the Node bot service.</p>
                <div class="action-row">
                    <a class="btn app-button-secondary" href="#bot-service-issues">Open section</a>
                </div>
            </article>

            <article class="content-card live-status-card">
                <span class="section-kicker">Application</span>
                <div class="card-heading">
                    <h3>App-Side Issues</h3>
                    <span class="compact-badge compact-badge-neutral">@Model.AppEntries.Count</span>
                </div>
                <p class="card-subtitle">Warnings and errors written by the ASP.NET app around bot and trade flow work.</p>
                <div class="action-row">
                    <a class="btn app-button-secondary" href="#application-issues">Open section</a>
                </div>
            </article>

            <article class="content-card live-status-card">
                <span class="section-kicker">Workflow</span>
                <div class="card-heading">
                    <h3>Workflow History</h3>
                    <span class="compact-badge compact-badge-neutral">@Model.WorkflowEntries.Count</span>
                </div>
                <p class="card-subtitle">Manual sell, credit, buy, delivery, and refresh actions in time order.</p>
                <div class="action-row">
                    <a class="btn app-button-secondary" href="#workflow-logs">Open section</a>
                </div>
            </article>
        </div>
    </section>

    <section class="page-section" id="bot-service-issues">
        <div class="section-heading">
            <div><h2>bot-service Issues</h2></div>
        </div>

        @if (recentBotIssues.Count == 0)
        {
            <div class="empty-state compact">
                <h3>No current bot-service issues.</h3>
            </div>
        }
        else
        {
            <div class="stack-grid">
                @foreach (var issue in recentBotIssues.Take(Model.Limit <= 0 ? 50 : Math.Min(Model.Limit, 200)))
                {
                    <article class="content-card history-card">
                        <div class="card-heading">
                            <div>
                                <h3>@issue.Message</h3>
                                <p class="card-subtitle">bot-service</p>
                            </div>
                            <span class="status-badge" data-status="@(string.Equals(issue.Level, "Error", StringComparison.OrdinalIgnoreCase) ? "Failed" : "Pending")">@issue.Level</span>
                        </div>
                        <div class="history-metrics">
                            <span><strong>At:</strong> @(issue.Timestamp?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz") ?? "Unknown")</span>
                            @foreach (var detail in issue.Details)
                            {
                                <span><strong>@detail.Key:</strong> <span class="break-value">@detail.Value</span></span>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="page-section" id="application-issues">
        <div class="section-heading">
            <div><h2>Application Issues</h2></div>
        </div>

        @if (Model.AppEntries.Count == 0)
        {
            <div class="empty-state compact">
                <h3>No app-side bot issues recorded.</h3>
            </div>
        }
        else
        {
            <div class="stack-grid">
                @foreach (var entry in Model.AppEntries)
                {
                    <article class="content-card history-card">
                        <div class="card-heading">
                            <div>
                                <h3>@entry.Message</h3>
                                <p class="card-subtitle">@entry.Source</p>
                            </div>
                            <span class="status-badge" data-status="@(string.Equals(entry.Level, "Error", StringComparison.OrdinalIgnoreCase) ? "Failed" : "Pending")">@entry.Level</span>
                        </div>
                        <div class="history-metrics">
                            <span><strong>At:</strong> @entry.TimestampUtc.ToLocalTime()</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(entry.StackTrace))
                        {
                            <details class="mt-2">
                                <summary>Stack trace</summary>
                                <pre class="meta-note mb-0">@entry.StackTrace</pre>
                            </details>
                        }
                    </article>
                }
            </div>
        }
    </section>

    <section class="page-section" id="workflow-logs">
        <div class="section-heading">
            <div>
                <h2>Workflow Logs</h2>
                <p class="section-description">Info, warning, and error entries for manual sell, credit, buy, delivery, and admin recovery actions.</p>
            </div>
        </div>

        @if (Model.WorkflowEntries.Count == 0)
        {
            <div class="empty-state compact">
                <h3>No workflow log entries yet.</h3>
            </div>
        }
        else
        {
            <div class="stack-grid">
                @foreach (var entry in Model.WorkflowEntries.Take(take))
                {
                    <article class="content-card history-card">
                        <div class="card-heading">
                            <div>
                                <h3>@entry.Message</h3>
                                <p class="card-subtitle">@entry.Source</p>
                            </div>
                            <span class="status-badge" data-status="@(string.Equals(entry.Level, "Error", StringComparison.OrdinalIgnoreCase) ? "Failed" : string.Equals(entry.Level, "Warning", StringComparison.OrdinalIgnoreCase) ? "Pending" : "Credited")">@entry.Level</span>
                        </div>
                        <div class="history-metrics">
                            <span><strong>At:</strong> @entry.TimestampUtc.ToLocalTime()</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(entry.StackTrace))
                        {
                            <details class="mt-2">
                                <summary>Stack trace</summary>
                                <pre class="meta-note mb-0">@entry.StackTrace</pre>
                            </details>
                        }
                    </article>
                }
            </div>
        }
    </section>
</div>
