@page
@model SkinMarket.Pages.Admin.BotStatusModel
@{
    ViewData["Title"] = "Bot Status";
    string FormatLocalDateTimeOffset(DateTimeOffset? timestamp, string fallback = "Never") => timestamp?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss zzz") ?? fallback;
    string ResolveServiceBadgeStatus(string? state) => !Model.ServiceStatus.Reachable
        ? "Failed"
        : state switch
        {
            "Ready" => "Credited",
            "Busy" or "Starting" or "Connecting" or "AwaitingWebSession" or "RefreshingSession" => "Pending",
            "Disabled" or "Misconfigured" or "Disconnected" or "Error" => "Failed",
            _ => Model.ServiceStatus.IsActive ? "Credited" : "Pending"
        };
    var botName = Model.BotProfile?.PersonaName ?? Model.BotSteamId ?? "Steam Bot";
    var serviceState = !Model.ServiceStatus.Reachable
        ? "Unavailable"
        : Model.ServiceStatus.Bot.ServiceState ?? "Unknown";
    var serviceBadgeStatus = ResolveServiceBadgeStatus(serviceState);
    var serviceStateDescription = !string.IsNullOrWhiteSpace(Model.ServiceStatus.Bot.ServiceStateDescription)
        ? Model.ServiceStatus.Bot.ServiceStateDescription
        : Model.ServiceStatus.ReachabilityError ?? "Bot state is unavailable.";
    var activeActivities = Model.ServiceStatus.Bot.ActiveActivities ?? new List<SkinMarket.Models.BotServiceActivitySnapshot>();
    var currentActivity = activeActivities
        .OrderBy(activity => activity.StartedAt)
        .FirstOrDefault();
    var recentBotIssues = Model.ServiceStatus.Bot.RecentIssues ?? new List<SkinMarket.Models.BotServiceIssueSnapshot>();
    var historyMode = string.IsNullOrWhiteSpace(Model.HistoryMode) ? "all" : Model.HistoryMode;
}

<div class="py-4">
    <div class="page-header">
        <div>
            <h1>Bot Status</h1>
            <p class="text-muted mb-0">Live Steam bot state, current work, and only the important failures.</p>
        </div>
        <div class="action-row">
            <a class="btn app-button-primary"
               asp-page="/Admin/BotStatus"
               asp-route-limit="@Model.Limit"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-historyMode="@(historyMode == "all" ? null : historyMode)">Bot Status</a>
            <a class="btn app-button-secondary"
               asp-page="/Admin/BotHistory"
               asp-route-limit="@Model.Limit"
               asp-route-searchTerm="@Model.SearchTerm"
               asp-route-historyMode="@(historyMode == "all" ? null : historyMode)">Bot History</a>
            <a class="btn app-button-secondary" asp-page="/Admin/Logs">Logs</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert alert-warning" role="alert">@Model.ErrorMessage</div>
    }

    @if (!Model.ServiceStatus.Reachable)
    {
        <div class="app-alert alert-danger" role="alert">
            Bot service is unreachable. @(Model.ServiceStatus.ReachabilityError ?? "No response from bot service.")
        </div>
    }

    <section class="page-section">
        <div class="history-tabs" data-admin-bot-status-tabs>
            <div class="history-tab-list" role="tablist" aria-label="Bot status sections">
                <button type="button" class="history-tab-button active" role="tab" aria-selected="true" data-admin-bot-status-tab="live">Live Bot State</button>
                <button type="button" class="history-tab-button" role="tab" aria-selected="false" data-admin-bot-status-tab="account">Account</button>
                <button type="button" class="history-tab-button" role="tab" aria-selected="false" data-admin-bot-status-tab="work">Current Work</button>
                <button type="button" class="history-tab-button" role="tab" aria-selected="false" data-admin-bot-status-tab="completed">Last Completed</button>
                <button type="button" class="history-tab-button" role="tab" aria-selected="false" data-admin-bot-status-tab="issues">Recent Issues</button>
            </div>

            <div class="history-tab-panel" data-admin-bot-status-panel="live">
                <div class="section-heading">
                    <div>
                        <h2>Live Bot State</h2>
                        <p class="section-description">Shows whether the bot is logging into Steam, waiting for the web session, or processing a trade right now.</p>
                    </div>
                    <div class="action-row" data-bot-live-refresh data-refresh-interval-seconds="15">
                        <span class="compact-badge compact-badge-neutral" data-bot-live-refresh-status>Auto refresh on</span>
                        <span class="meta-note" data-bot-live-refresh-countdown>Refresh in 15s.</span>
                        <button type="button" class="btn app-button-secondary" data-bot-live-refresh-toggle>Pause auto refresh</button>
                        <a class="btn app-button-primary"
                           asp-page="/Admin/BotStatus"
                           asp-route-limit="@Model.Limit"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-historyMode="@(historyMode == "all" ? null : historyMode)">Refresh now</a>
                    </div>
                </div>

                <div class="card-grid live-status-grid">
                    <article class="content-card live-status-card">
                        <span class="section-kicker">Current State</span>
                        <div class="card-heading">
                            <h3>@serviceState</h3>
                            <span class="status-badge" data-status="@serviceBadgeStatus">@serviceState</span>
                        </div>
                        <p class="card-subtitle">@serviceStateDescription</p>
                        <div class="history-metrics">
                            <span><strong>State updated:</strong> @FormatLocalDateTimeOffset(Model.ServiceStatus.Bot.StateUpdatedAt)</span>
                            <span><strong>Service reachable:</strong> @(Model.ServiceStatus.Reachable ? "Yes" : "No")</span>
                        </div>
                    </article>

                    <article class="content-card live-status-card">
                        <span class="section-kicker">Steam Login</span>
                        <div class="card-heading">
                            <h3>@(Model.ServiceStatus.Bot.LoggedOn ? "Logged into Steam" : "Steam login pending")</h3>
                            <span class="status-badge" data-status="@(Model.ServiceStatus.Bot.LoggedOn ? "Credited" : serviceBadgeStatus)">@(Model.ServiceStatus.Bot.LoggedOn ? "Logged On" : "Waiting")</span>
                        </div>
                        <p class="card-subtitle">@(
                            Model.ServiceStatus.Bot.LoggedOn
                                ? "Steam account session is authenticated."
                                : serviceStateDescription)</p>
                        <div class="history-metrics">
                            <span><strong>Username configured:</strong> @(Model.ServiceStatus.Bot.UsernameConfigured ? "Yes" : "No")</span>
                            <span><strong>Shared secret:</strong> @(Model.ServiceStatus.Bot.SharedSecretConfigured ? "Yes" : "No")</span>
                            <span><strong>Identity secret:</strong> @(Model.ServiceStatus.Bot.IdentitySecretConfigured ? "Yes" : "No")</span>
                        </div>
                    </article>

                    <article class="content-card live-status-card">
                        <span class="section-kicker">Web Session</span>
                        <div class="card-heading">
                            <h3>@(Model.ServiceStatus.Bot.Ready ? "Trade manager ready" : "Waiting for web session")</h3>
                            <span class="status-badge" data-status="@(Model.ServiceStatus.Bot.Ready ? "Credited" : serviceBadgeStatus)">@(Model.ServiceStatus.Bot.Ready ? "Ready" : "Waiting")</span>
                        </div>
                        <p class="card-subtitle">@(
                            Model.ServiceStatus.Bot.Ready
                                ? "Steam cookies and trade manager session are ready for work."
                                : "The bot may already be logged into Steam but still waiting for cookies or a refreshed web session.")</p>
                        <div class="history-metrics">
                            <span><strong>Last ready:</strong> @FormatLocalDateTimeOffset(Model.ServiceStatus.Bot.LastReadyAt)</span>
                            <span><strong>Active activities:</strong> @Model.ServiceStatus.Bot.ActiveActivityCount</span>
                        </div>
                    </article>
                </div>
            </div>

            <div class="history-tab-panel" data-admin-bot-status-panel="account" hidden>
        <section class="content-card profile-card">
            <div class="card-heading">
                <h2>Account</h2>
                <span class="status-badge" data-status="@serviceBadgeStatus">@serviceState</span>
            </div>
            <div class="profile-identity">
                @if (!string.IsNullOrWhiteSpace(Model.BotProfile?.AvatarFull))
                {
                    <img class="profile-avatar" src="@Model.BotProfile.AvatarFull" alt="@botName" />
                }
                else
                {
                    <div class="profile-avatar profile-avatar-fallback" aria-hidden="true">
                        @((botName.FirstOrDefault()).ToString().ToUpperInvariant())
                    </div>
                }
                <div>
                    <h3 class="profile-name">@botName</h3>
                    <p class="card-subtitle mb-0 break-value">@Model.BotSteamId</p>
                </div>
            </div>
            <dl class="detail-list">
                <div class="detail-row">
                    <dt>Service Reachable</dt>
                    <dd>@(Model.ServiceStatus.Reachable ? "Yes" : "No")</dd>
                </div>
                <div class="detail-row">
                    <dt>Bot Enabled</dt>
                    <dd>@(Model.BotEnabled ? "Yes" : "No")</dd>
                </div>
                <div class="detail-row">
                    <dt>Steam Session Ready</dt>
                    <dd>@(Model.ServiceStatus.Bot.Ready ? "Yes" : "No")</dd>
                </div>
                <div class="detail-row">
                    <dt>Logged On</dt>
                    <dd>@(Model.ServiceStatus.Bot.LoggedOn ? "Yes" : "No")</dd>
                </div>
                <div class="detail-row">
                    <dt>State</dt>
                    <dd>@serviceStateDescription</dd>
                </div>
                <div class="detail-row">
                    <dt>State Updated</dt>
                    <dd>@FormatLocalDateTimeOffset(Model.ServiceStatus.Bot.StateUpdatedAt)</dd>
                </div>
                <div class="detail-row">
                    <dt>Last Ready</dt>
                    <dd>@FormatLocalDateTimeOffset(Model.ServiceStatus.Bot.LastReadyAt)</dd>
                </div>
                <div class="detail-row">
                    <dt>Last Error</dt>
                    <dd class="break-value">@(string.IsNullOrWhiteSpace(Model.ServiceStatus.Bot.LastError) ? "None" : Model.ServiceStatus.Bot.LastError)</dd>
                </div>
                <div class="detail-row">
                    <dt>Trade URL</dt>
                    <dd class="break-value">@(string.IsNullOrWhiteSpace(Model.BotTradeUrl) ? "Not configured" : Model.BotTradeUrl)</dd>
                </div>
                <div class="detail-row">
                    <dt>Service URL</dt>
                    <dd class="break-value">@Model.ServiceUrl</dd>
                </div>
            </dl>
        </section>
            </div>

            <div class="history-tab-panel" data-admin-bot-status-panel="work" hidden>
        <section class="content-card">
            <div class="card-heading">
                <h2>Current Work</h2>
                <span class="compact-badge compact-badge-neutral">Active @Model.ServiceStatus.Bot.ActiveActivityCount</span>
            </div>

            <div class="live-state-summary">
                <span><strong>Service focus:</strong> @serviceStateDescription</span>
                <span><strong>State updated:</strong> @FormatLocalDateTimeOffset(Model.ServiceStatus.Bot.StateUpdatedAt)</span>
            </div>

            @if (activeActivities.Count == 0)
            {
                <div class="meta-note mb-3">Bot is currently idle.</div>
            }
            else
            {
                <div class="stack-grid">
                    @foreach (var activity in activeActivities)
                    {
                        <article class="history-card">
                            <div class="card-heading">
                                <div>
                                    <h3>@activity.Description</h3>
                                    <p class="card-subtitle">@activity.Type</p>
                                </div>
                                <span class="status-badge" data-status="Pending">Running</span>
                            </div>
                            <div class="history-metrics">
                                <span><strong>Started:</strong> @FormatLocalDateTimeOffset(activity.StartedAt, "Unknown")</span>
                                @foreach (var detail in activity.Meta)
                                {
                                    <span><strong>@detail.Key:</strong> <span class="break-value">@detail.Value</span></span>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
            </div>

            <div class="history-tab-panel" data-admin-bot-status-panel="completed" hidden>
        <section class="content-card">
                <h3>Last Completed</h3>
                @if (Model.ServiceStatus.Bot.LastCompletedActivity is null)
                {
                    <div class="meta-note">No completed bot activity recorded yet.</div>
                }
                else
                {
                    var activity = Model.ServiceStatus.Bot.LastCompletedActivity;
                    <article class="history-card">
                        <div class="card-heading">
                            <div>
                                <h3>@activity.Description</h3>
                                <p class="card-subtitle">@activity.Type</p>
                            </div>
                            <span class="status-badge" data-status="@(string.Equals(activity.Result, "Succeeded", StringComparison.OrdinalIgnoreCase) ? "Credited" : "Failed")">@activity.Result</span>
                        </div>
                        <div class="history-metrics">
                            <span><strong>Started:</strong> @FormatLocalDateTimeOffset(activity.StartedAt, "Unknown")</span>
                            <span><strong>Finished:</strong> @FormatLocalDateTimeOffset(activity.CompletedAt, "Unknown")</span>
                            @foreach (var detail in activity.Meta)
                            {
                                <span><strong>@detail.Key:</strong> <span class="break-value">@detail.Value</span></span>
                            }
                        </div>
                    </article>
                }
        </section>
            </div>

            <div class="history-tab-panel" data-admin-bot-status-panel="issues" hidden>
        <section class="content-card">
            <div class="card-heading">
                <h2>Recent Issues</h2>
                <a class="btn app-button-primary" asp-page="/Admin/Logs" asp-route-limit="50">Open Logs</a>
            </div>
            <div class="card-grid mt-3">
                <article class="content-card live-status-card">
                <span class="section-kicker">bot-service</span>
                <div class="card-heading">
                    <h3>Current Issues</h3>
                    <span class="compact-badge compact-badge-neutral">@recentBotIssues.Count</span>
                </div>
                <p class="card-subtitle">Warnings and errors coming directly from the bot HTTP service.</p>
            </article>

            <article class="content-card live-status-card">
                <span class="section-kicker">Application</span>
                <div class="card-heading">
                    <h3>App-Side Issues</h3>
                    <span class="compact-badge compact-badge-neutral">@Model.RecentAppIssues.Count</span>
                </div>
                <p class="card-subtitle">Warnings and errors written by the ASP.NET app around intake, credit, delivery, and sync.</p>
            </article>

            <article class="content-card live-status-card">
                <span class="section-kicker">Workflow</span>
                <div class="card-heading">
                    <h3>Recent Actions</h3>
                    <span class="compact-badge compact-badge-neutral">@Model.RecentWorkflowEntries.Count</span>
                </div>
                <p class="card-subtitle">Manual and automatic workflow entries now live on the separate Logs page.</p>
            </article>
            </div>
        </section>
            </div>
        </div>
    </section>

</div>

@section Scripts {
    <script>
        (() => {
            const root = document.querySelector('[data-bot-live-refresh]');
            if (!root) {
                return;
            }

            const status = root.querySelector('[data-bot-live-refresh-status]');
            const countdown = root.querySelector('[data-bot-live-refresh-countdown]');
            const toggle = root.querySelector('[data-bot-live-refresh-toggle]');
            const intervalSeconds = Number(root.dataset.refreshIntervalSeconds || '15');
            const storageKey = 'skinmarket-admin-botstatus-autorefresh';
            let enabled = localStorage.getItem(storageKey) !== 'off';
            let remainingSeconds = intervalSeconds;

            const isEditingFilters = () => {
                const activeElement = document.activeElement;
                return activeElement instanceof HTMLElement &&
                    activeElement.closest('[data-pause-refresh]') !== null;
            };

            const render = () => {
                if (!status || !countdown || !toggle) {
                    return;
                }

                if (!enabled) {
                    status.textContent = 'Auto refresh paused';
                    countdown.textContent = 'Page refresh is paused.';
                    toggle.textContent = 'Resume auto refresh';
                    return;
                }

                status.textContent = 'Auto refresh on';
                toggle.textContent = 'Pause auto refresh';
                countdown.textContent = isEditingFilters()
                    ? 'Paused while filters are focused.'
                    : `Refresh in ${remainingSeconds}s.`;
            };

            toggle?.addEventListener('click', () => {
                enabled = !enabled;
                localStorage.setItem(storageKey, enabled ? 'on' : 'off');
                remainingSeconds = intervalSeconds;
                render();
            });

            render();

            window.setInterval(() => {
                if (!enabled) {
                    return;
                }

                if (isEditingFilters()) {
                    remainingSeconds = intervalSeconds;
                    render();
                    return;
                }

                remainingSeconds -= 1;
                if (remainingSeconds <= 0) {
                    window.location.reload();
                    return;
                }

                render();
            }, 1000);
        })();

        (() => {
            const root = document.querySelector('[data-admin-bot-status-tabs]');
            if (!root) {
                return;
            }

            const tabs = Array.from(root.querySelectorAll('[data-admin-bot-status-tab]'));
            const panels = Array.from(root.querySelectorAll('[data-admin-bot-status-panel]'));
            const storageKey = 'skinmarket-admin-bot-status-tab';

            const activate = (target) => {
                if (!tabs.some((tab) => tab.dataset.adminBotStatusTab === target)) {
                    return;
                }

                tabs.forEach((candidate) => {
                    const isActive = candidate.dataset.adminBotStatusTab === target;
                    candidate.classList.toggle('active', isActive);
                    candidate.setAttribute('aria-selected', isActive ? 'true' : 'false');
                });

                panels.forEach((panel) => {
                    panel.hidden = panel.dataset.adminBotStatusPanel !== target;
                });
            };

            activate(localStorage.getItem(storageKey) || 'live');

            tabs.forEach((tab) => {
                tab.addEventListener('click', () => {
                    const target = tab.dataset.adminBotStatusTab;
                    localStorage.setItem(storageKey, target);
                    activate(target);
                });
            });
        })();

    </script>
}
