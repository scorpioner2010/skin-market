@page
@model SkinMarket.Pages.InventoryModel
@using System.Linq
@using System.Text.Json
@{
    ViewData["Title"] = L["Page_Inventory_Title"];
    var pendingStatuses = new HashSet<string>(StringComparer.Ordinal)
    {
        "Pending",
        "BotPending",
        "AwaitingBotConfirmation",
        "TradeCreated",
        "AwaitingUserAction",
        "TradeAcceptedPendingReceipt",
        "InEscrow",
        "PendingDelivery",
        "DeliveryBotPending",
        "DeliveryTradeCreated",
        "AwaitingBuyerAction",
        "DeliveryInEscrow"
    };
    var waitingForCreditStatuses = new HashSet<string>(StringComparer.Ordinal)
    {
        "ReceivedByBot"
    };
    var readyToSellCount = Model.GroupedItems.Count(item => item.HasSellableItem);
    var pendingTradeCount = Model.GroupedItems.Count(item =>
        item.StatusItems.Any(statusItem => !statusItem.IsReady && pendingStatuses.Contains(statusItem.Status)));
    var waitingForCreditCount = Model.GroupedItems.Count(item =>
        item.HasWaitingForCredit ||
        item.StatusItems.Any(statusItem => !statusItem.IsReady && waitingForCreditStatuses.Contains(statusItem.Status)));
}

<div class="py-4">
    <div class="page-header">
        <div>
            <h1>@L["Page_Inventory_Title"]</h1>
            <p class="page-description inventory-page-description">@L["Inventory_LiveDescription"]</p>
            <div class="status-group inventory-summary-strip">
                <span class="compact-badge compact-badge-neutral">@L["Inventory_Grouped"]: @Model.GroupedItems.Count</span>
                <span class="compact-badge compact-badge-neutral">@L["Inventory_SummaryReady"]: @readyToSellCount</span>
                <span class="compact-badge compact-badge-neutral">@L["Inventory_SummaryPending"]: @pendingTradeCount</span>
                <span class="compact-badge compact-badge-neutral">@L["Inventory_CreditWait"]: @waitingForCreditCount</span>
            </div>
        </div>
        <div class="status-group">
            <form method="get" class="game-switcher" aria-label="@L["Inventory_GameSelector"]">
                <label class="game-switcher-label" for="inventory-game">@L["Common_Game"]</label>
                <select id="inventory-game" name="game" class="form-select app-input game-switcher-select" onchange="this.form.submit()">
                    @foreach (var game in Model.SupportedGames.Where(item => item.SupportsInventory))
                    {
                        if (game.Type == Model.CurrentGameType)
                        {
                            <option value="@game.Type" selected>@game.DisplayName</option>
                        }
                        else
                        {
                            <option value="@game.Type">@game.DisplayName</option>
                        }
                    }
                </select>
            </form>
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <div class="inventory-refresh-controls"
                     data-inventory-refresh-root
                     data-game-type="@((int)Model.CurrentGameType)"
                     data-last-success-utc="@Model.InventoryLastSuccessRefreshUtc?.ToString("O")"
                     data-refreshing="@Model.InventoryRefreshInProgress.ToString().ToLowerInvariant()"
                     data-refresh-reason="@Model.InventoryRefreshReason">
                    <span class="inventory-refresh-status" data-inventory-refresh-status>
                        @Model.GetInventoryRefreshStatusText()
                    </span>
                </div>
            }
        </div>
    </div>

    @if (!(User.Identity?.IsAuthenticated ?? false))
    {
        <div class="empty-state">
            <h2>@L["Common_SteamLoginRequired"]</h2>
            <a class="btn app-button-primary" asp-page="/Auth/Login">@L["Common_LoginWithSteam"]</a>
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="app-alert alert-success" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.SuccessMessage)</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.SellErrorMessage))
        {
            <div class="app-alert alert-danger" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.SellErrorMessage)</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.TradeStatusMessage))
        {
            <div class="app-alert alert-warning" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.TradeStatusMessage)</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.WarningMessage))
        {
            <div class="app-alert alert-warning" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.WarningMessage)</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.InventorySnapshotWarningMessage))
        {
            <div class="app-alert alert-warning" role="alert">@Model.InventorySnapshotWarningMessage</div>
        }

        @if (!Model.IsTradeUrlConfigured)
        {
            <div class="trade-url-setup trade-url-setup-critical">
                <div class="trade-url-setup-copy">
                    <strong>@L["Inventory_TradeUrlRequired_Title"]</strong>
                    <span>@L["Inventory_TradeUrlRequired_Text"]</span>
                </div>
                <div class="trade-url-setup-actions">
                    <a class="btn app-button-primary" asp-page="/Profile">@L["Common_OpenProfile"]</a>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="app-alert alert-danger" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.ErrorMessage)</div>
        }
        else if (Model.InventoryIsLoading)
        {
            <div class="empty-state">
                <h2>Loading inventory...</h2>
                <p>The first inventory snapshot is being refreshed in the background.</p>
            </div>
        }
        else if (Model.GroupedItems.Count == 0)
        {
            <div class="empty-state">
                <h2>@L["Inventory_Empty_Title"]</h2>
                <p>@L["Inventory_Empty_Text"]</p>
            </div>
        }
        else
        {
            <section class="page-section">
                <div class="section-heading">
                    <div>
                        <h2>@L["Inventory_YourItems_Title"]</h2>
                        <p class="section-description">@L["Inventory_SellableDescription"]</p>
                    </div>
                </div>
                <div class="inventory-table-shell">
                    <div class="inventory-list">
                        <div class="inventory-row inventory-row-header">
                            <div class="inventory-cell inventory-item-cell">@L["Inventory_Column_Item"]</div>
                            <div class="inventory-cell inventory-flag-cell">@L["Inventory_Column_Tradable"]</div>
                            <div class="inventory-cell inventory-flag-cell">@L["Inventory_Column_Marketable"]</div>
                            <div class="inventory-cell">@L["Common_QuantityShort"]</div>
                            <div class="inventory-cell">USD price</div>
                            <div class="inventory-cell inventory-status-cell">@L["Inventory_Column_Status"]</div>
                            <div class="inventory-cell inventory-actions-cell">@L["Inventory_Column_Action"]</div>
                        </div>
                        @foreach (var item in Model.GroupedItems)
                        {
                            <article class="inventory-row" data-inventory-sale-row data-asset-ids="@string.Join("|", item.AssetIds)" data-quantity="@item.Quantity">
                                <div class="inventory-cell inventory-item-cell" data-label="@L["Inventory_Column_Item"]">
                                    <div class="inventory-main">
                                        @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                        {
                                            <img src="@item.IconUrl" alt="@item.ItemName" class="inventory-icon" />
                                        }
                                        else
                                        {
                                            <div class="inventory-icon inventory-icon-fallback" aria-hidden="true">
                                                @((item.ItemName.FirstOrDefault()).ToString().ToUpperInvariant())
                                            </div>
                                        }
                                        <div class="inventory-main-copy">
                                            <div class="inventory-title-row">
                                                <h2 class="inventory-item-name">@item.ItemName</h2>
                                            </div>
                                            <div class="inventory-meta inventory-instance-line">
                                                @if (!string.IsNullOrWhiteSpace(item.MarketHashName))
                                                {
                                                    <span class="break-value">@item.MarketHashName</span>
                                                }
                                                else
                                                {
                                                    <span class="break-value">@L["Inventory_InstanceId"]: @item.InstanceId</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="inventory-cell inventory-flag-cell" data-label="@L["Inventory_Column_Tradable"]">
                                    <div class="inventory-badges">
                                        <span class="compact-badge">@((item.Tradable.HasValue ? L[item.Tradable.Value ? "Common_Yes" : "Common_No"] : L["Common_Unknown"]).Value)</span>
                                    </div>
                                </div>
                                <div class="inventory-cell inventory-flag-cell" data-label="@L["Inventory_Column_Marketable"]">
                                    <div class="inventory-badges">
                                        <span class="compact-badge">@((item.Marketable.HasValue ? L[item.Marketable.Value ? "Common_Yes" : "Common_No"] : L["Common_Unknown"]).Value)</span>
                                    </div>
                                </div>
                                <div class="inventory-cell inventory-meta break-value" data-label="@L["Common_QuantityShort"]">
                                    <span class="balance-pill inventory-count-pill">@item.Quantity</span>
                                </div>
                                <div class="inventory-cell inventory-meta inventory-price-cell"
                                     data-label="USD price"
                                     data-asset-id="@item.RepresentativeAssetId"
                                     data-market-hash-name="@item.MarketHashName"
                                     data-price-source="@Model.ResolvedPricesByAssetId.GetValueOrDefault(item.RepresentativeAssetId)?.Source"
                                     data-price-type="@Model.ResolvedPricesByAssetId.GetValueOrDefault(item.RepresentativeAssetId)?.PriceType"
                                     data-price-confidence="@Model.ResolvedPricesByAssetId.GetValueOrDefault(item.RepresentativeAssetId)?.ConfidenceLabel">
                                    @{
                                        var resolvedPrice = Model.ResolvedPricesByAssetId.GetValueOrDefault(item.RepresentativeAssetId);
                                    }
                                    @if (resolvedPrice?.Status == "Refreshing")
                                    {
                                        <div class="inventory-price-block">
                                            <span class="inventory-unavailable">@L["PriceStatus_Refreshing"]</span>
                                        </div>
                                    }
                                    else if (resolvedPrice?.HasPrice == true && resolvedPrice.Price is decimal realPrice)
                                    {
                                        <div class="inventory-price-block">
                                            <span class="price-value">@Model.GetPriceDisplayText(resolvedPrice)</span>
                                            <span class="inventory-meta">@Model.GetPriceStatusLabel(resolvedPrice) · @Model.GetPriceSourceLabel(resolvedPrice.Source)</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="inventory-price-block">
                                            <span class="inventory-unavailable">No reliable price</span>
                                        </div>
                                    }
                                </div>
                                <div class="inventory-cell inventory-status-cell" data-label="@L["Inventory_Column_Status"]" data-sale-status-cell data-trade-flow-status-cell>
                                    @if (item.StatusItems.Count > 0)
                                    {
                                        <div class="inventory-status inventory-status-summary">
                                            @foreach (var statusItem in item.StatusItems)
                                            {
                                                <span class="status-badge" data-status="@(statusItem.IsReady ? "Available" : statusItem.Status)">
                                                    @(statusItem.IsReady ? L["Inventory_Ready"].Value : UiTextLocalizer.LocalizeStatus(L, statusItem.Status)) @($"x{statusItem.Quantity}")
                                                </span>
                                                @if (statusItem.CreditAmountTotal > 0)
                                                {
                                                    <span class="mini-pill">@L["Inventory_Credited"]: @statusItem.CreditAmountTotal</span>
                                                }
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="compact-badge compact-badge-neutral">@L["Inventory_Ready"]</span>
                                    }
                                </div>
                                <div class="inventory-cell inventory-actions-cell" data-label="@L["Inventory_Column_Action"]">
                                    <div class="inventory-actions" data-sale-action-cell>
                                        @{
                                            var action = item.ActionDecision;
                                        }
                                        @if (action.Kind == InventoryItemActionKinds.Sell)
                                        {
                                            <form method="post" asp-page-handler="Sell" data-trade-blockable-form data-trade-block-message="@L["Inventory_TradeBlockMessageSell"]">
                                                <input type="hidden" name="Input.GameType" value="@Model.CurrentGameType" />
                                                <input type="hidden" name="Input.AssetId" value="@item.SellAssetId" />
                                                <input type="hidden" name="Input.ClassId" value="@item.SellClassId" />
                                                <input type="hidden" name="Input.InstanceId" value="@item.SellInstanceId" />
                                                <input type="hidden" name="Input.ItemName" value="@item.SellItemName" />
                                                <input type="hidden" name="Input.MarketHashName" value="@item.SellMarketHashName" />
                                                <input type="hidden" name="Input.IconUrl" value="@item.SellIconUrl" />
                                                <button type="submit" class="btn app-button-primary">@L["Common_Sell"]</button>
                                            </form>
                                        }
                                        else if (action.Kind == InventoryItemActionKinds.TradeUrlRequired)
                                        {
                                            <span class="compact-badge compact-badge-neutral">@L["Inventory_TradeUrlRequired"]</span>
                                        }
                                        else if (action.Kind == InventoryItemActionKinds.AwaitingSellerAcceptance)
                                        {
                                            <span class="compact-badge compact-badge-neutral">@L["Inventory_AwaitingSellerAcceptance"]</span>
                                        }
                                        else if (action.Kind == InventoryItemActionKinds.FailedRetry && item.CreateTradeOperationId.HasValue)
                                        {
                                            <form method="post" asp-page-handler="CreateTrade">
                                                <input type="hidden" name="Input.GameType" value="@Model.CurrentGameType" />
                                                <input type="hidden" name="Input.TradeOperationId" value="@item.CreateTradeOperationId" />
                                                <button type="submit" class="btn app-button-secondary">@L["Inventory_CreateTrade"]</button>
                                            </form>
                                        }
                                        else if (action.Kind == InventoryItemActionKinds.CreatingTradeOffer)
                                        {
                                            <span class="compact-badge compact-badge-neutral">@L["Inventory_CreatingTradeOffer"]</span>
                                        }
                                        else if (action.Kind == InventoryItemActionKinds.AwaitingBotConfirmation)
                                        {
                                            <span class="compact-badge compact-badge-neutral">@UiTextLocalizer.LocalizeStatus(L, "AwaitingBotConfirmation")</span>
                                        }
                                        else if (action.Kind == InventoryItemActionKinds.WaitingForCredit)
                                        {
                                            <span class="compact-badge compact-badge-neutral">@L["Inventory_WaitingForCredit"]</span>
                                        }
                                        else if (action.Kind == InventoryItemActionKinds.TradeProtected)
                                        {
                                            <span class="compact-badge compact-badge-neutral">@UiTextLocalizer.LocalizeStatus(L, "TradeProtected")</span>
                                        }
                                        else
                                        {
                                            <span class="compact-badge compact-badge-neutral" title="@item.ActionDecision.DiagnosticReason">@L["Inventory_StateIssue"]</span>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            </section>
        }

    }
</div>

@if (Model.PricePollingItems.Count > 0)
{
    <script type="application/json" id="inventory-price-items">@Html.Raw(JsonSerializer.Serialize(Model.PricePollingItems))</script>
}

@section Scripts {
    <script>
        (() => {
            const root = document.querySelector('[data-inventory-refresh-root]');
            if (!root) {
                return;
            }

            const statusElement = root.querySelector('[data-inventory-refresh-status]');
            const requestBody = {
                gameType: Number(root.dataset.gameType || @((int)Model.CurrentGameType))
            };
            const tradeRefreshReasons = new Set([
                'TradeCreated',
                'TradeAccepted',
                'UserSoldItem',
                'UserBoughtItem',
                'ItemDelivered',
                'ItemCredited'
            ]);
            let lastSuccessUtc = root.dataset.lastSuccessUtc || null;
            let isRefreshing = root.dataset.refreshing === 'true';
            let statusPollTimer = null;

            const read = (entry, camelName, pascalName) => entry?.[camelName] ?? entry?.[pascalName] ?? null;
            const formatAge = (date) => {
                const seconds = Math.max(0, Math.floor((Date.now() - date.getTime()) / 1000));
                if (seconds < 60) {
                    return 'less than 1 minute';
                }

                const minutes = Math.floor(seconds / 60);
                if (minutes < 60) {
                    return minutes === 1 ? '1 minute' : `${minutes} minutes`;
                }

                const hours = Math.floor(minutes / 60);
                if (hours < 24) {
                    return hours === 1 ? '1 hour' : `${hours} hours`;
                }

                const days = Math.floor(hours / 24);
                return days === 1 ? '1 day' : `${days} days`;
            };

            const fetchStatus = async (url) => {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(requestBody)
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                return await response.json();
            };

            const render = (status) => {
                const previousLastSuccessUtc = lastSuccessUtc;
                const wasRefreshing = isRefreshing;
                const lastSuccessValue = read(status, 'lastSuccessRefreshUtc', 'LastSuccessRefreshUtc');
                const refreshReason = read(status, 'refreshReason', 'RefreshReason');
                isRefreshing = Boolean(read(status, 'isRefreshing', 'IsRefreshing'));
                lastSuccessUtc = lastSuccessValue || null;

                if (statusElement) {
                    if (isRefreshing) {
                        statusElement.textContent = tradeRefreshReasons.has(refreshReason)
                            ? 'Syncing inventory after trade...'
                            : 'Updating inventory...';
                    } else if (lastSuccessValue) {
                        statusElement.textContent = `Inventory last updated: ${formatAge(new Date(lastSuccessValue))} ago.`;
                    } else {
                        statusElement.textContent = 'Loading inventory...';
                    }
                }

                if (!isRefreshing &&
                    lastSuccessValue &&
                    (!previousLastSuccessUtc || (wasRefreshing && previousLastSuccessUtc !== lastSuccessValue))) {
                    window.setTimeout(() => window.location.reload(), 250);
                }
            };

            const scheduleStatusPoll = () => {
                window.clearTimeout(statusPollTimer);
                if (!isRefreshing && lastSuccessUtc) {
                    return;
                }

                statusPollTimer = window.setTimeout(async () => {
                    try {
                        render(await fetchStatus('/api/inventory/status'));
                    } catch {
                    } finally {
                        scheduleStatusPoll();
                    }
                }, 3000);
            };

            scheduleStatusPoll();
        })();

        (() => {
            const payloadElement = document.getElementById('inventory-price-items');
            if (!payloadElement) {
                return;
            }

            const items = JSON.parse(payloadElement.textContent || '[]');
            if (!Array.isArray(items) || items.length === 0) {
                return;
            }

            const statusUrl = '/api/inventory/prices/status';
            const refreshUrl = '/api/inventory/prices/refresh';
            const requestBody = {
                gameType: @((int)Model.CurrentGameType),
                items
            };

            const updateCell = (entry) => {
                const cell = document.querySelector(`.inventory-price-cell[data-asset-id="${entry.assetId}"]`);
                if (!cell) {
                    return;
                }

                if (entry.status === 'Refreshing') {
                    cell.innerHTML = `<div class="inventory-price-block"><span class="inventory-unavailable">@L["PriceStatus_Refreshing"]</span></div>`;
                    return;
                }

                if (entry.hasPrice && entry.price !== null) {
                    const display = entry.displayPrice || `${entry.isEstimated ? '~' : ''}$${Number(entry.price).toFixed(2)}`;
                    const label = entry.isStale ? 'Stale' : entry.isEstimated ? 'Estimated' : entry.isCached ? 'Cached' : (entry.source || 'Live');
                    cell.dataset.priceSource = entry.source || 'Unavailable';
                    cell.dataset.priceType = entry.priceType || 'unavailable';
                    cell.dataset.priceConfidence = entry.confidenceLabel || '';
                    cell.innerHTML = `<div class="inventory-price-block"><span class="price-value">${display.split(' ')[0]}</span><span class="inventory-meta">${label} · ${entry.source || 'Unavailable'}</span></div>`;
                    return;
                }

                cell.innerHTML = `<div class="inventory-price-block"><span class="inventory-unavailable">No reliable price</span></div>`;
            };

            const fetchJson = async (url) => {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(requestBody)
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                return await response.json();
            };

            let pollCount = 0;
            const maxPolls = 60;

            const poll = async () => {
                pollCount += 1;
                try {
                    const data = await fetchJson(statusUrl);
                    const statuses = Array.isArray(data?.items) ? data.items : [];
                    let hasRefreshing = false;
                    for (const entry of statuses) {
                        updateCell(entry);
                        if (entry.status === 'Refreshing') {
                            hasRefreshing = true;
                        }
                    }

                    if (hasRefreshing && pollCount < maxPolls) {
                        window.setTimeout(poll, 2500);
                    }
                } catch {
                }
            };

            fetchJson(refreshUrl)
                .catch(() => null)
                .finally(() => {
                    window.setTimeout(poll, 1200);
                });
        })();

    </script>
}
