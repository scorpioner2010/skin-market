@page
@model SkinMarket.Pages.InventoryModel
@using System.Linq
@using System.Text.Json
@{
    ViewData["Title"] = L["Page_Inventory_Title"];
    var pendingStatuses = new HashSet<string>(StringComparer.Ordinal)
    {
        "Pending",
        "BotPending",
        "AwaitingBotConfirmation",
        "TradeCreated",
        "AwaitingUserAction",
        "TradeAcceptedPendingReceipt",
        "InEscrow"
    };
    var waitingForCreditStatuses = new HashSet<string>(StringComparer.Ordinal)
    {
        "ReceivedByBot"
    };
    var readyToSellCount = Model.GroupedItems.Count(item => item.HasSellableItem);
    var pendingTradeCount = Model.GroupedItems.Count(item =>
        item.StatusItems.Any(statusItem => !statusItem.IsReady && pendingStatuses.Contains(statusItem.Status)));
    var waitingForCreditCount = Model.GroupedItems.Count(item =>
        item.HasWaitingForCredit ||
        item.StatusItems.Any(statusItem => !statusItem.IsReady && waitingForCreditStatuses.Contains(statusItem.Status)));
}

<div class="py-4">
    <div class="page-header">
        <div>
            <h1>@L["Page_Inventory_Title"]</h1>
            <p class="page-description inventory-page-description">Live Steam inventory with grouped duplicates, current price resolution, and trade flow status.</p>
            <div class="status-group inventory-summary-strip">
                <span class="compact-badge compact-badge-neutral">Grouped: @Model.GroupedItems.Count</span>
                <span class="compact-badge compact-badge-neutral">Ready: @readyToSellCount</span>
                <span class="compact-badge compact-badge-neutral">Pending: @pendingTradeCount</span>
                <span class="compact-badge compact-badge-neutral">Credit wait: @waitingForCreditCount</span>
            </div>
        </div>
        <div class="status-group">
            <span class="compact-badge compact-badge-neutral">@Model.CurrentGameDisplayName</span>
        </div>
    </div>

    @if (!(User.Identity?.IsAuthenticated ?? false))
    {
        <div class="empty-state">
            <h2>@L["Common_SteamLoginRequired"]</h2>
            <a class="btn app-button-primary" asp-page="/Auth/Login">@L["Common_LoginWithSteam"]</a>
        </div>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="app-alert alert-success" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.SuccessMessage)</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.SellErrorMessage))
        {
            <div class="app-alert alert-danger" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.SellErrorMessage)</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.TradeStatusMessage))
        {
            <div class="app-alert alert-warning" role="alert">@Model.TradeStatusMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.WarningMessage))
        {
            <div class="app-alert alert-warning" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.WarningMessage)</div>
        }

        @if (Model.CanUpdateTradeUrl && !Model.IsTradeUrlConfigured)
        {
            <div class="trade-url-setup" data-trade-url-setup>
                <div class="trade-url-setup-copy">
                    <strong>Trade URL is required before selling.</strong>
                    <span>Open Steam trade settings, copy your Trade URL, then click Update Trade URL here. The page will save it automatically if it matches your Steam account.</span>
                </div>
                <div class="trade-url-setup-actions">
                    <a class="btn app-button-secondary" href="@Model.SteamTradeSettingsUrl" target="_blank" rel="noopener">Open Steam Trade URL page</a>
                    <form method="post" asp-page-handler="UpdateTradeUrl" class="trade-url-update-form" data-trade-url-form>
                        <input type="hidden" asp-for="TradeUrlUpdate.TradeUrl" data-trade-url-input />
                        <button type="button" class="btn app-button-primary" data-trade-url-update-button>Update Trade URL</button>
                    </form>
                </div>
                <div class="trade-url-status" data-trade-url-status role="status" aria-live="polite" hidden></div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="app-alert alert-danger" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.ErrorMessage)</div>
        }
        else if (Model.GroupedItems.Count == 0)
        {
            <div class="empty-state">
                <h2>@L["Inventory_Empty_Title"]</h2>
                <p>@L["Inventory_Empty_Text"]</p>
            </div>
        }
        else
        {
            <section class="page-section">
                <div class="section-heading">
                    <div>
                        <h2>@L["Inventory_YourItems_Title"]</h2>
                        <p class="section-description">Sellable items, price, and trade status.</p>
                    </div>
                </div>
                <div class="inventory-table-shell">
                    <div class="inventory-list">
                        <div class="inventory-row inventory-row-header">
                            <div class="inventory-cell inventory-item-cell">@L["Inventory_Column_Item"]</div>
                            <div class="inventory-cell inventory-flag-cell">@L["Inventory_Column_Tradable"]</div>
                            <div class="inventory-cell inventory-flag-cell">@L["Inventory_Column_Marketable"]</div>
                            <div class="inventory-cell">Qty</div>
                            <div class="inventory-cell">@L["Inventory_Column_RealPrice"]</div>
                            <div class="inventory-cell inventory-status-cell">@L["Inventory_Column_Status"]</div>
                            <div class="inventory-cell inventory-actions-cell">@L["Inventory_Column_Action"]</div>
                        </div>
                        @foreach (var item in Model.GroupedItems)
                        {
                            <article class="inventory-row" data-inventory-sale-row data-asset-ids="@string.Join("|", item.AssetIds)" data-quantity="@item.Quantity">
                                <div class="inventory-cell inventory-item-cell" data-label="@L["Inventory_Column_Item"]">
                                    <div class="inventory-main">
                                        @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                        {
                                            <img src="@item.IconUrl" alt="@item.ItemName" class="inventory-icon" />
                                        }
                                        else
                                        {
                                            <div class="inventory-icon inventory-icon-fallback" aria-hidden="true">
                                                @((item.ItemName.FirstOrDefault()).ToString().ToUpperInvariant())
                                            </div>
                                        }
                                        <div class="inventory-main-copy">
                                            <div class="inventory-title-row">
                                                <h2 class="inventory-item-name">@item.ItemName</h2>
                                            </div>
                                            <div class="inventory-meta inventory-instance-line">
                                                @if (!string.IsNullOrWhiteSpace(item.MarketHashName))
                                                {
                                                    <span class="break-value">@item.MarketHashName</span>
                                                }
                                                else
                                                {
                                                    <span class="break-value">Instance ID: @item.InstanceId</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="inventory-cell inventory-flag-cell" data-label="@L["Inventory_Column_Tradable"]">
                                    <div class="inventory-badges">
                                        <span class="compact-badge">@((item.Tradable.HasValue ? L[item.Tradable.Value ? "Common_Yes" : "Common_No"] : L["Common_Unknown"]).Value)</span>
                                    </div>
                                </div>
                                <div class="inventory-cell inventory-flag-cell" data-label="@L["Inventory_Column_Marketable"]">
                                    <div class="inventory-badges">
                                        <span class="compact-badge">@((item.Marketable.HasValue ? L[item.Marketable.Value ? "Common_Yes" : "Common_No"] : L["Common_Unknown"]).Value)</span>
                                    </div>
                                </div>
                                <div class="inventory-cell inventory-meta break-value" data-label="Qty">
                                    <span class="balance-pill inventory-count-pill">@item.Quantity</span>
                                </div>
                                <div class="inventory-cell inventory-meta inventory-price-cell" data-label="@L["Inventory_Column_RealPrice"]" data-asset-id="@item.RepresentativeAssetId" data-market-hash-name="@item.MarketHashName">
                                    @{
                                        var resolvedPrice = Model.ResolvedPricesByAssetId.GetValueOrDefault(item.RepresentativeAssetId);
                                    }
                                    @if (resolvedPrice?.Status == "Refreshing")
                                    {
                                        <div class="inventory-price-block">
                                            <span class="inventory-unavailable">@L["PriceStatus_Refreshing"]</span>
                                        </div>
                                    }
                                    else if (resolvedPrice?.HasPrice == true && resolvedPrice.Price is decimal realPrice)
                                    {
                                        <div class="inventory-price-block">
                                            <span class="price-value">@(resolvedPrice.IsEstimated ? "~" : string.Empty)$@realPrice.ToString("0.00")</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="inventory-price-block">
                                            <span class="inventory-unavailable">@L["PriceStatus_NoPrice"]</span>
                                        </div>
                                    }
                                </div>
                                <div class="inventory-cell inventory-status-cell" data-label="@L["Inventory_Column_Status"]" data-sale-status-cell data-trade-flow-status-cell>
                                    @if (item.StatusItems.Count > 0)
                                    {
                                        <div class="inventory-status inventory-status-summary">
                                            @foreach (var statusItem in item.StatusItems)
                                            {
                                                <span class="status-badge" data-status="@(statusItem.IsReady ? "Available" : statusItem.Status)">
                                                    @(statusItem.IsReady ? L["Inventory_Ready"].Value : UiTextLocalizer.LocalizeStatus(L, statusItem.Status)) @($"x{statusItem.Quantity}")
                                                </span>
                                                @if (statusItem.CreditAmountTotal > 0)
                                                {
                                                    <span class="mini-pill">@L["Inventory_Credited"]: @statusItem.CreditAmountTotal</span>
                                                }
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="compact-badge compact-badge-neutral">@L["Inventory_Ready"]</span>
                                    }
                                </div>
                                <div class="inventory-cell inventory-actions-cell" data-label="@L["Inventory_Column_Action"]">
                                    <div class="inventory-actions" data-sale-action-cell>
                                        @if (item.HasSellableItem && Model.IsTradeUrlConfigured)
                                        {
                                            <form method="post" asp-page-handler="Sell" data-trade-blockable-form data-trade-block-message="Finish or cancel the active trade offer before selling another item.">
                                                <input type="hidden" name="Input.AssetId" value="@item.SellAssetId" />
                                                <input type="hidden" name="Input.ClassId" value="@item.SellClassId" />
                                                <input type="hidden" name="Input.InstanceId" value="@item.SellInstanceId" />
                                                <input type="hidden" name="Input.ItemName" value="@item.SellItemName" />
                                                <input type="hidden" name="Input.MarketHashName" value="@item.SellMarketHashName" />
                                                <input type="hidden" name="Input.IconUrl" value="@item.SellIconUrl" />
                                                <button type="submit" class="btn app-button-primary">@L["Common_Sell"]</button>
                                            </form>
                                        }
                                        else if (item.HasSellableItem)
                                        {
                                            <button type="button" class="btn app-button-secondary" data-trade-url-update-button>Update Trade URL</button>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(item.AwaitingUserTradeOfferId))
                                        {
                                            <span class="compact-badge compact-badge-neutral">Action required</span>
                                        }
                                        else if (item.CreateTradeOperationId.HasValue &&
                                                 string.Equals(item.CreateTradeStatus, "Failed", StringComparison.Ordinal))
                                        {
                                            <form method="post" asp-page-handler="CreateTrade">
                                                <input type="hidden" name="Input.TradeOperationId" value="@item.CreateTradeOperationId" />
                                                <button type="submit" class="btn app-button-secondary">@L["Inventory_CreateTrade"]</button>
                                            </form>
                                        }
                                        else if (item.CreateTradeOperationId.HasValue)
                                        {
                                            <span class="compact-badge compact-badge-neutral">Auto trade pending</span>
                                        }
                                        else if (item.HasWaitingForCredit)
                                        {
                                            <span class="compact-badge compact-badge-neutral">Waiting for credit</span>
                                        }
                                        else if (item.HasTradeProtected)
                                        {
                                            <span class="compact-badge compact-badge-neutral">Trade protected</span>
                                        }
                                        else
                                        {
                                            <span class="compact-badge compact-badge-neutral">@L["Inventory_PendingSale"]</span>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            </section>
        }

    }
</div>

@if (Model.PricePollingItems.Count > 0)
{
    <script type="application/json" id="inventory-price-items">@Html.Raw(JsonSerializer.Serialize(Model.PricePollingItems))</script>
}

@section Scripts {
    <script>
        (() => {
            const payloadElement = document.getElementById('inventory-price-items');
            if (!payloadElement) {
                return;
            }

            const items = JSON.parse(payloadElement.textContent || '[]');
            if (!Array.isArray(items) || items.length === 0) {
                return;
            }

            const statusUrl = '/api/inventory/prices/status';
            const refreshUrl = '/api/inventory/prices/refresh';
            const requestBody = {
                gameType: @((int)Model.CurrentGameType),
                items
            };

            const updateCell = (entry) => {
                const cell = document.querySelector(`.inventory-price-cell[data-asset-id="${entry.assetId}"]`);
                if (!cell) {
                    return;
                }

                if (entry.status === 'Refreshing') {
                    cell.innerHTML = `<div class="inventory-price-block"><span class="inventory-unavailable">@L["PriceStatus_Refreshing"]</span></div>`;
                    return;
                }

                if (entry.hasPrice && entry.price !== null) {
                    const prefix = entry.isEstimated ? '~' : '';
                    cell.innerHTML = `<div class="inventory-price-block"><span class="price-value">${prefix}$${Number(entry.price).toFixed(2)}</span></div>`;
                    return;
                }

                cell.innerHTML = `<div class="inventory-price-block"><span class="inventory-unavailable">@L["PriceStatus_NoPrice"]</span></div>`;
            };

            const fetchJson = async (url) => {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(requestBody)
                });

                if (!response.ok) {
                    throw new Error(`HTTP ${response.status}`);
                }

                return await response.json();
            };

            let pollCount = 0;
            const maxPolls = 60;

            const poll = async () => {
                pollCount += 1;
                try {
                    const data = await fetchJson(statusUrl);
                    const statuses = Array.isArray(data?.items) ? data.items : [];
                    let hasRefreshing = false;
                    for (const entry of statuses) {
                        updateCell(entry);
                        if (entry.status === 'Refreshing') {
                            hasRefreshing = true;
                        }
                    }

                    if (hasRefreshing && pollCount < maxPolls) {
                        window.setTimeout(poll, 2500);
                    }
                } catch {
                }
            };

            fetchJson(refreshUrl)
                .catch(() => null)
                .finally(() => {
                    window.setTimeout(poll, 1200);
                });
        })();

        (() => {
            const form = document.querySelector('[data-trade-url-form]');
            if (!form) {
                return;
            }

            const input = form.querySelector('[data-trade-url-input]');
            const status = document.querySelector('[data-trade-url-status]');
            const buttons = document.querySelectorAll('[data-trade-url-update-button]');
            const tradeUrlExpression = /https:\/\/steamcommunity\.com\/tradeoffer\/new\/\?[^\s<>"']+/i;
            if (!input) {
                return;
            }

            const setStatus = (state, message) => {
                if (!status) {
                    return;
                }

                status.hidden = false;
                status.dataset.state = state;
                status.textContent = message;
                if (state !== 'waiting') {
                    status.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            };

            const setBusy = (busy) => {
                buttons.forEach((button) => {
                    if (!button.dataset.originalText) {
                        button.dataset.originalText = button.textContent || 'Update Trade URL';
                    }

                    button.disabled = busy;
                    button.textContent = busy ? 'Updating...' : button.dataset.originalText;
                });
            };

            const readTradeUrlFromClipboard = async () => {
                if (!navigator.clipboard?.readText) {
                    throw new Error('Clipboard access is not available in this browser.');
                }

                const clipboardText = (await navigator.clipboard.readText()).trim();
                const match = clipboardText.match(tradeUrlExpression);
                if (!match) {
                    throw new Error('Clipboard does not contain a Steam Trade URL.');
                }

                return match[0];
            };

            const updateTradeUrl = async () => {
                setBusy(true);
                setStatus('waiting', 'Waiting for Trade URL...');

                try {
                    const tradeUrl = await readTradeUrlFromClipboard();
                    input.value = tradeUrl;

                    const response = await fetch(form.action, {
                        method: 'POST',
                        body: new FormData(form),
                        credentials: 'same-origin',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    const payload = await response.json().catch(() => null);
                    if (!response.ok || payload?.success !== true) {
                        throw new Error(payload?.message || 'Could not update Trade URL.');
                    }

                    setStatus('success', payload.message || 'Trade URL saved.');
                    window.setTimeout(() => window.location.reload(), 900);
                } catch (error) {
                    const message = error instanceof Error ? error.message : 'Could not update Trade URL.';
                    setStatus('failed', `${message} Copy your Steam Trade URL first, then click Update Trade URL again.`);
                } finally {
                    setBusy(false);
                }
            };

            buttons.forEach((button) => {
                button.addEventListener('click', updateTradeUrl);
            });
        })();
    </script>
}
