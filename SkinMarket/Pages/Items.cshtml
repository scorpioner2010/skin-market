@page
@model SkinMarket.Pages.ItemsModel
@{
    ViewData["Title"] = L["Page_Items_Title"];
    string FormatLocalDateTime(DateTime timestamp) => timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
}

<div class="market-page items-page py-4">
    <div class="page-header">
        <div>
            <h1>@L["Page_Items_Title"]</h1>
            <p class="text-muted mb-0">@L["Items_Description"]</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert alert-danger" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.ErrorMessage)</div>
    }

    @if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h2>@L["Items_Empty_Title"]</h2>
        </div>
    }
    else
    {
        <section class="page-section">
            <div class="section-heading">
                <div>
                    <h2>@L["Page_Items_Title"]</h2>
                    <p class="section-description">@L["Items_AvailableSummary", Model.Items.Count]</p>
                </div>
                <div class="market-view-toggle" role="group" aria-label="@L["Items_View"]">
                    <button type="button" class="market-view-button active" data-market-view-button="cards">@L["Common_Cards"]</button>
                    <button type="button" class="market-view-button" data-market-view-button="table">@L["Common_Table"]</button>
                </div>
            </div>

            <div class="card-grid market-card-grid" data-market-view-panel="cards">
                @foreach (var item in Model.Items)
                {
                    <article class="content-card item-card market-item-card">
                        <div class="market-item-top">
                            <div class="market-item-visual">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" class="item-icon market-item-icon" />
                                }
                                else
                                {
                                    <div class="market-item-icon-fallback" aria-hidden="true">
                                        @((item.Name.FirstOrDefault()).ToString().ToUpperInvariant())
                                    </div>
                                }
                            </div>
                            <div class="market-item-copy">
                                <div class="market-item-head">
                                    <div>
                                        <h2 class="card-title market-item-title">@item.Name</h2>
                                        @if (!string.IsNullOrWhiteSpace(item.Description))
                                        {
                                            <p class="card-subtitle market-item-subtitle">@item.Description</p>
                                        }
                                    </div>
                                    <div class="market-price-block">
                                        <span class="compact-badge market-quantity-badge">@L["Items_Type_ServiceItem"]</span>
                                        <span class="market-price-label">@L["Common_Price"]</span>
                                        <p class="price-tag market-price-tag">$@item.Price.ToString("0.00")</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <dl class="detail-list compact market-detail-list">
                            <div class="detail-row market-detail-row">
                                <dt>@L["Common_ItemId"]</dt>
                                <dd class="break-value market-detail-value">@item.Id</dd>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <div class="detail-row market-detail-row">
                                    <dt>@L["Common_Description"]</dt>
                                    <dd class="break-value market-detail-value">@item.Description</dd>
                                </div>
                            }
                        </dl>

                        <p class="meta-note market-owner-note">@L["Common_Created"]: @FormatLocalDateTime(item.CreatedAtUtc)</p>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <form method="post" asp-page-handler="OpenChat" class="action-row market-item-actions">
                                <input type="hidden" asp-for="ChatItemId" value="@item.Id" />
                                <button type="submit" class="btn app-button-primary market-action-button">@L["Common_Chat"]</button>
                            </form>
                        }
                        else
                        {
                            <div class="action-row market-item-actions">
                                <a class="btn app-button-primary market-action-button" asp-page="/Auth/Login">@L["Common_Chat"]</a>
                            </div>
                        }
                    </article>
                }
            </div>
            <div class="market-table-shell" data-market-view-panel="table" hidden>
                <div class="market-table-list">
                    <div class="market-table-row market-table-header">
                        <div class="market-table-cell market-table-item-cell">@L["Common_Item"]</div>
                        <div class="market-table-cell">@L["Common_Type"]</div>
                        <div class="market-table-cell">@L["Common_Price"]</div>
                        <div class="market-table-cell">@L["Common_Created"]</div>
                        <div class="market-table-cell market-table-asset-cell">@L["Common_ItemId"]</div>
                        <div class="market-table-cell market-table-actions-cell">@L["Common_Action"]</div>
                    </div>
                    @foreach (var item in Model.Items)
                    {
                        <article class="market-table-row">
                            <div class="market-table-cell market-table-item-cell" data-label="@L["Common_Item"]">
                                <div class="market-table-main">
                                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name" class="inventory-icon" />
                                    }
                                    else
                                    {
                                        <div class="inventory-icon inventory-icon-fallback" aria-hidden="true">
                                            @((item.Name.FirstOrDefault()).ToString().ToUpperInvariant())
                                        </div>
                                    }
                                    <div class="market-table-copy">
                                        <h2 class="inventory-item-name">@item.Name</h2>
                                        @if (!string.IsNullOrWhiteSpace(item.Description))
                                        {
                                            <div class="inventory-meta market-table-subtitle">@item.Description</div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="market-table-cell" data-label="@L["Common_Type"]">
                                <span class="balance-pill inventory-count-pill">@L["Items_Type_ServiceItem"]</span>
                            </div>
                            <div class="market-table-cell" data-label="@L["Common_Price"]">
                                <span class="price-value">$@item.Price.ToString("0.00")</span>
                            </div>
                            <div class="market-table-cell" data-label="@L["Common_Created"]">
                                <span class="inventory-meta">@FormatLocalDateTime(item.CreatedAtUtc)</span>
                            </div>
                            <div class="market-table-cell market-table-asset-cell" data-label="@L["Common_ItemId"]">
                                <span class="inventory-meta break-value">@item.Id</span>
                            </div>
                            <div class="market-table-cell market-table-actions-cell" data-label="@L["Common_Action"]">
                                @if (User.Identity?.IsAuthenticated ?? false)
                                {
                                    <form method="post" asp-page-handler="OpenChat" class="market-table-action-form">
                                        <input type="hidden" name="ChatItemId" value="@item.Id" />
                                        <button type="submit" class="btn app-button-primary market-table-action-button">@L["Common_Chat"]</button>
                                    </form>
                                }
                                else
                                {
                                    <a class="btn app-button-primary market-table-action-button" asp-page="/Auth/Login">@L["Common_Chat"]</a>
                                }
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>
    }
</div>

@section Scripts {
    <script>
        (() => {
            const buttons = Array.from(document.querySelectorAll('[data-market-view-button]'));
            const panels = Array.from(document.querySelectorAll('[data-market-view-panel]'));
            if (buttons.length === 0 || panels.length === 0) {
                return;
            }

            const storageKey = 'skinmarket-items-view';
            const activate = (view) => {
                const target = view === 'table' ? 'table' : 'cards';

                buttons.forEach((button) => {
                    button.classList.toggle('active', button.dataset.marketViewButton === target);
                });

                panels.forEach((panel) => {
                    panel.hidden = panel.dataset.marketViewPanel !== target;
                });
            };

            activate(localStorage.getItem(storageKey) || 'cards');

            buttons.forEach((button) => {
                button.addEventListener('click', () => {
                    const view = button.dataset.marketViewButton || 'cards';
                    localStorage.setItem(storageKey, view);
                    activate(view);
                });
            });
        })();
    </script>
}
