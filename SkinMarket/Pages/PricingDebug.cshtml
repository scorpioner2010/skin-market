@page
@model SkinMarket.Pages.PricingDebugModel
@{
    ViewData["Title"] = L["Page_PricingDebug_Title"];
}

<div class="py-4">
    <div class="page-header">
        <div>
            <span class="section-kicker">@L["PricingDebug_Kicker"]</span>
            <h1>@L["Page_PricingDebug_Title"]</h1>
            <p class="page-description">@L["PricingDebug_Description"]</p>
        </div>
    </div>

    @if (!(User.Identity?.IsAuthenticated ?? false))
    {
        <div class="empty-state">
            <h2>@L["Common_SteamLoginRequired"]</h2>
            <p>@L["PricingDebug_LoginRequired_Text"]</p>
            <a class="btn app-button-primary" asp-page="/Auth/Login">@L["Common_LoginWithSteam"]</a>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert alert-danger" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.ErrorMessage)</div>
    }
    else if (Model.Items.Count == 0)
    {
        <div class="empty-state">
            <h2>@L["PricingDebug_Empty_Title"]</h2>
            <p>@L["PricingDebug_Empty_Text"]</p>
        </div>
    }
    else
    {
        <div class="debug-table-wrap">
            <table class="table debug-table">
                <thead>
                    <tr>
                        <th>@L["Common_Item"]</th>
                        <th>@L["PricingDebug_AssetId"]</th>
                        <th>@L["PricingDebug_ClassId"]</th>
                        <th>@L["PricingDebug_MarketHashName"]</th>
                        <th>@L["PricingDebug_MarketName"]</th>
                        <th>@L["PricingDebug_ResolvedMarketHashName"]</th>
                        <th>@L["PricingDebug_SteamMarket"]</th>
                        <th>CSFloat</th>
                        <th>Skinport</th>
                        <th>@L["PricingDebug_Final"]</th>
                        <th>@L["PricingDebug_Source"]</th>
                        <th>@L["Common_Status"]</th>
                        <th>@L["PricingDebug_Errors"]</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="break-value">@item.ItemName</td>
                        <td class="break-value">@item.AssetId</td>
                        <td class="break-value">@item.ClassId</td>
                        <td class="break-value">@item.MarketHashName</td>
                        <td class="break-value">@item.MarketName</td>
                        <td class="break-value">@item.ResolvedMarketHashName</td>
                        <td>@(item.SteamPrice.HasValue ? $"${item.SteamPrice.Value:0.00} ({item.SteamStatus})" : item.SteamStatus ?? "-")</td>
                        <td>@(item.CsFloatPrice.HasValue ? $"${item.CsFloatPrice.Value:0.00} ({item.CsFloatStatus})" : item.CsFloatStatus ?? "-")</td>
                        <td>@(item.SkinportPrice.HasValue ? $"${item.SkinportPrice.Value:0.00} ({item.SkinportStatus})" : item.SkinportStatus ?? "-")</td>
                        <td>@(item.FinalPrice.HasValue ? $"${item.FinalPrice.Value:0.00}" : "-")</td>
                        <td><span class="compact-badge compact-badge-neutral">@item.FinalSource</span></td>
                        <td><span class="compact-badge compact-badge-neutral">@item.FinalStatus</span></td>
                        <td class="debug-errors">
                            @if (!string.IsNullOrWhiteSpace(item.SteamError))
                            {
                                <div><strong>Steam:</strong> @item.SteamError</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.CsFloatError))
                            {
                                <div><strong>CSFloat:</strong> @item.CsFloatError</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.SkinportError))
                            {
                                <div><strong>Skinport:</strong> @item.SkinportError</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.FailureReason))
                            {
                                <div><strong>@L["PricingDebug_Final"]:</strong> @item.FailureReason</div>
                            }
                            @if (string.IsNullOrWhiteSpace(item.SteamError) &&
                                 string.IsNullOrWhiteSpace(item.CsFloatError) &&
                                 string.IsNullOrWhiteSpace(item.SkinportError) &&
                                 string.IsNullOrWhiteSpace(item.FailureReason))
                            {
                                <span>-</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
