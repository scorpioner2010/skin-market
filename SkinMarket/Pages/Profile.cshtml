@page
@model SkinMarket.Pages.ProfileModel
@{
    ViewData["Title"] = L["Page_Profile_Title"];
    var profileName = string.IsNullOrWhiteSpace(Model.SteamPersonaName) ? Model.AppUser?.DisplayName : Model.SteamPersonaName;
    profileName ??= L["Profile_SteamUserFallback"].Value;
    var avatarAlt = string.Format(L["Profile_AvatarAlt"].Value, profileName ?? L["Profile_SteamUserFallback"].Value);
    var isTradeUrlConfigured = !string.IsNullOrWhiteSpace(Model.AppUser?.TradeUrl);
}

<div class="py-4">
    <div class="page-header">
        <div>
            <h1>@L["Page_Profile_Title"]</h1>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert alert-warning" role="alert">@Model.ErrorMessage</div>
    }
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="app-alert alert-success" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.SuccessMessage)</div>
        }

        <div class="profile-grid">
            <section class="content-card profile-card">
                <div class="card-heading">
                    <h2>@L["Profile_AccountSummary"]</h2>
                    <span class="status-badge" data-status="Credited">@UiTextLocalizer.LocalizeStatus(L, "Credited")</span>
                </div>
                <div class="profile-identity">
                    @if (!string.IsNullOrWhiteSpace(Model.SteamAvatarUrl))
                    {
                        <img class="profile-avatar" src="@Model.SteamAvatarUrl" alt="@avatarAlt" />
                    }
                    else
                    {
                        <div class="profile-avatar profile-avatar-fallback" aria-hidden="true">
                            @((Model.AppUser?.DisplayName?.FirstOrDefault() ?? 'S').ToString().ToUpperInvariant())
                        </div>
                    }
                    <div>
                        <h3 class="profile-name">@profileName</h3>
                    </div>
                </div>

                <section class="profile-balance-panel" aria-labelledby="profile-balance-title">
                    <div class="profile-balance-copy">
                        <span class="profile-balance-label" id="profile-balance-title">@L["Profile_Balance"]</span>
                        <strong class="profile-balance-value">$@Model.Balance.ToString("0.00")</strong>
                        <span class="profile-balance-note">Цей баланс можна витратити на сервіси сайту, ігри та покупки на маркеті. Вивести його в реальні кошти неможливо.</span>
                    </div>
                </section>

                <dl class="detail-list">
                    <div class="detail-row">
                        <dt>SteamID</dt>
                        <dd class="break-value">@Model.AppUser?.SteamId</dd>
                    </div>
                    <div class="detail-row">
                        <dt>@L["Profile_PersonaName"]</dt>
                        <dd>@profileName</dd>
                    </div>
                    <div class="detail-row">
                        <dt>@L["Profile_DisplayName"]</dt>
                        <dd>@Model.AppUser?.DisplayName</dd>
                    </div>
                    <div class="detail-row">
                        <dt>@L["Profile_AvatarUrl"]</dt>
                        <dd class="break-value">@(string.IsNullOrWhiteSpace(Model.SteamAvatarUrl) ? L["Profile_AvatarUnavailable"] : Model.SteamAvatarUrl)</dd>
                    </div>
                    <div class="detail-row @(isTradeUrlConfigured ? string.Empty : "trade-url-critical-row")">
                        <dt>@L["Profile_TradeUrl"]</dt>
                        <dd class="break-value">@(string.IsNullOrWhiteSpace(Model.AppUser?.TradeUrl) ? L["Profile_TradeUrl_NotSet"] : Model.AppUser?.TradeUrl)</dd>
                    </div>
                    <div class="detail-row">
                        <dt>@L["Common_Created"]</dt>
                        <dd>@Model.AppUser?.CreatedAtUtc</dd>
                    </div>
                    <div class="detail-row">
                        <dt>@L["Profile_LocalUserId"]</dt>
                        <dd class="break-value">@Model.AppUser?.Id</dd>
                    </div>
                </dl>
            </section>

            <section class="content-card @(isTradeUrlConfigured ? string.Empty : "trade-url-critical-card")">
                <div class="card-heading">
                    <h2>@L["Profile_TradeSettings"]</h2>
                    @if (!isTradeUrlConfigured)
                    {
                        <span class="status-badge" data-status="Pending">Required</span>
                    }
                </div>
                <form method="post" class="stack-form">
                    @if (!isTradeUrlConfigured)
                    {
                        <div class="trade-url-critical-message" role="alert">
                            Trade URL is required before selling. Open the Steam page, copy the full Trade URL, paste it here, then save.
                        </div>
                    }
                    <div>
                        <label asp-for="Input.TradeUrl" class="form-label">@L["Profile_SteamTradeUrl"]</label>
                        <input asp-for="Input.TradeUrl" class="form-control app-input" placeholder="@L["Profile_TradeUrl_Placeholder"]" />
                        <span asp-validation-for="Input.TradeUrl" class="text-danger small"></span>
                    </div>
                    <div class="trade-url-form-actions">
                        <button type="submit" class="btn app-button-primary">@L["Profile_SaveTradeUrl"]</button>
                        <a class="btn app-button-secondary" href="https://steamcommunity.com/my/tradeoffers/privacy#trade_offer_access_url" target="_blank" rel="noopener">Open Steam page</a>
                    </div>
                </form>
            </section>

            <section class="content-card">
                <div class="card-heading">
                    <h2>Gift code</h2>
                    @if (Model.AppUser?.IsAdmin == true)
                    {
                        <span class="status-badge" data-status="Credited">Admin active</span>
                    }
                </div>
                <form method="post" asp-page-handler="ActivateGiftCode" class="stack-form">
                    <div>
                        <label asp-for="GiftCodeInput.Code" class="form-label">Gift code</label>
                        <input asp-for="GiftCodeInput.Code" class="form-control app-input" placeholder="Enter gift code" autocomplete="off" />
                        <span asp-validation-for="GiftCodeInput.Code" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn app-button-secondary">Enter</button>
                </form>
            </section>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h2>@L["Common_SteamLoginRequired"]</h2>
            <a class="btn app-button-primary" asp-page="/Auth/Login">@L["Common_LoginWithSteam"]</a>
        </div>
    }
</div>
