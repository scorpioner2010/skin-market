@page
@model ErrorModel
@{
    ViewData["Title"] = L["Page_Error_Title"];
}

<div class="py-4">
    <section class="content-card">
        <div class="page-header">
            <div>
                <h1>@L["Page_Error_Title"]</h1>
                <p class="page-description">@L["Error_Description"]</p>
            </div>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="app-alert alert-warning" role="alert">
                <strong>@L["Error_RequestId"]:</strong> <code>@Model.RequestId</code>
            </div>
        }

        <div class="stack-grid narrow">
            <article class="content-card">
                <h2>@L["Error_DevelopmentMode"]</h2>
                <p class="meta-note">@L["Error_DevelopmentMode_Text"]</p>
            </article>
            <article class="content-card">
                <h2>@L["Error_SecurityNote"]</h2>
                <p class="meta-note">@L["Error_SecurityNote_Text"]</p>
            </article>
        </div>
    </section>
</div>
