@page
@model IndexModel
@{
    ViewData["Title"] = L["Page_Home_Title"];
}

<section class="hero-card">
    <div class="hero-copy">
        <span class="section-kicker">@L["Home_Kicker"]</span>
        <h1 class="hero-title">SkinMarket</h1>
        <p class="hero-text">@L["Home_HeroText"]</p>
        <div class="hero-actions">
            <a class="btn app-button-primary" asp-page="/Market">@L["Home_OpenMarket"]</a>
            <a class="btn app-button-secondary" asp-page="/Inventory">@L["Home_ViewInventory"]</a>
        </div>
    </div>
    <div class="hero-panel">
        <div class="hero-stat">
            <span class="hero-stat-label">@L["Home_Workflow_Label"]</span>
            <strong>@L["Home_Workflow_Value"]</strong>
        </div>
        <div class="hero-stat">
            <span class="hero-stat-label">@L["Home_Focus_Label"]</span>
            <strong>@L["Home_Focus_Value"]</strong>
        </div>
    </div>
</section>

<section class="page-section">
    <div class="section-heading">
        <div>
            <h2>@L["Home_Overview_Title"]</h2>
            <p>@L["Home_Overview_Description"]</p>
        </div>
    </div>
    <div class="feature-grid">
        <article class="info-card">
            <h3>@L["Home_Feature_Profile_Title"]</h3>
            <p>@L["Home_Feature_Profile_Text"]</p>
        </article>
        <article class="info-card">
            <h3>@L["Home_Feature_Inventory_Title"]</h3>
            <p>@L["Home_Feature_Inventory_Text"]</p>
        </article>
        <article class="info-card">
            <h3>@L["Home_Feature_Market_Title"]</h3>
            <p>@L["Home_Feature_Market_Text"]</p>
        </article>
    </div>
</section>
