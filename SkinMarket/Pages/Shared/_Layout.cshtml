<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - x-mania</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SkinMarket.styles.css" asp-append-version="true" />
</head>
<body class="app-body">
    @inject SkinMarket.Infrastructure.AppRuntimeState RuntimeState
    @{
        var userAvatarUrl = User.FindFirst("AvatarUrl")?.Value;
        var userDisplayName = User.Identity?.Name ?? User.FindFirst("SteamId")?.Value ?? L["Layout_UserFallback"];
        var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        var layoutSubtitle = currentCulture switch
        {
            "uk" => "Сервіс ігрових предметів",
            "ru" => "Сервис игровых предметов",
            _ => "Game item service"
        };
        var returnUrl = $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";
        var currentPath = Context.Request.Path.Value ?? string.Empty;
        string IsActivePage(string path) => currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
    }
    <header class="app-header">
        <div class="app-shell">
            <div class="app-topbar">
                <a class="app-brand" asp-area="" asp-page="/Index">
                    <span class="app-brand-mark">SM</span>
                    <span class="app-brand-copy">
                        <span class="app-brand-title">x-mania</span>
                        <span class="app-brand-subtitle">@layoutSubtitle</span>
                    </span>
                </a>
                <div class="app-topbar-right">
                    <div class="language-switch" role="group" aria-label="@L["Layout_Language"]">
                        <a class="language-switch-link @(currentCulture == "en" ? "active" : null)" href="/set-language?culture=en&amp;returnUrl=@Uri.EscapeDataString(returnUrl)">EN</a>
                        <a class="language-switch-link @(currentCulture == "uk" ? "active" : null)" href="/set-language?culture=uk&amp;returnUrl=@Uri.EscapeDataString(returnUrl)">UA</a>
                        <a class="language-switch-link @(currentCulture == "ru" ? "active" : null)" href="/set-language?culture=ru&amp;returnUrl=@Uri.EscapeDataString(returnUrl)">RU</a>
                    </div>
                    <div class="app-auth-panel">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <span class="app-auth-chip">
                                @if (!string.IsNullOrWhiteSpace(userAvatarUrl))
                                {
                                    <img class="app-auth-avatar" src="@userAvatarUrl" alt="@L["Layout_UserAvatarAlt"]" />
                                }
                                else
                                {
                                    <span class="app-auth-avatar app-auth-avatar-fallback" aria-hidden="true">
                                        @((userDisplayName.FirstOrDefault()).ToString().ToUpperInvariant())
                                    </span>
                                }
                                <span class="break-value">@userDisplayName</span>
                            </span>
                            <a class="btn btn-sm app-button-secondary" asp-page="/Auth/Logout">@L["Layout_Logout"]</a>
                        }
                        else
                        {
                            <a class="btn btn-sm app-button-primary" asp-page="/Auth/Login">@L["Common_LoginWithSteam"]</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="app-shell">
        <div class="app-body-wrap">
            <aside class="app-sidebar">
                <nav class="app-side-nav">
                    <a class="app-side-link @IsActivePage("/Profile")" asp-page="/Profile">@L["Layout_Nav_Profile"]</a>
                    <a class="app-side-link @IsActivePage("/Market")" asp-page="/Market">@L["Layout_Nav_Market"]</a>
                    <a class="app-side-link @IsActivePage("/Inventory")" asp-page="/Inventory">@L["Layout_Nav_Inventory"]</a>
                    <a class="app-side-link @IsActivePage("/History")" asp-page="/History">@L["Layout_Nav_History"]</a>
                    <a class="app-side-link @IsActivePage("/Admin")" asp-page="/Admin/BotStatus">Admin</a>
                </nav>
                <div class="app-sidebar-card">
                    <div><strong>x-mania</strong></div>
                    <div>@layoutSubtitle</div>
                </div>
            </aside>

            <main role="main" class="app-main">
                <div class="app-content-column">
                    @if (RuntimeState.IsDegradedMode)
                    {
                        <div class="app-alert alert-warning mt-3" role="alert">@RuntimeState.ServiceUnavailableMessage</div>
                    }

                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <footer class="app-footer">
        <div class="app-shell app-footer-inner">
            <div><strong>x-mania</strong></div>
            <div class="app-footer-text">@layoutSubtitle</div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
