@page
@model SkinMarket.Pages.GamesModel
@{
    ViewData["Title"] = "Games";
}

<div class="games-page py-4">
    <div class="page-header">
        <div>
            <h1>Games</h1>
            <p class="text-muted mb-0">Unity WebGL games connected to the x-mania service will appear here.</p>
        </div>
    </div>

    @if (Model.Games.Count == 0)
    {
        <div class="empty-state games-empty-state">
            <h2>No games available yet</h2>
            <p class="text-muted mb-0">This section is prepared for future Unity WebGL integrations.</p>
        </div>
    }
    else
    {
        <section class="page-section">
            <div class="section-heading">
                <div>
                    <h2>Available games</h2>
                    <p class="section-description">@Model.Games.Count game(s) connected.</p>
                </div>
            </div>

            <div class="card-grid games-card-grid">
                @foreach (var game in Model.Games)
                {
                    <article class="content-card game-card">
                        <div class="game-card-mark" aria-hidden="true">@game.ShortName</div>
                        <div>
                            <h2 class="card-title">@game.Name</h2>
                            <p class="card-subtitle">@game.Description</p>
                        </div>
                        <span class="compact-badge">@game.Status</span>
                        <a class="btn app-button-secondary" asp-page="/Games/Minefield">Open</a>
                    </article>
                }
            </div>
        </section>
    }
</div>
