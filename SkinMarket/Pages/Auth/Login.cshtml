@page
@model SkinMarket.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="py-4">
    <section class="hero-card">
        <div>
            <span class="section-kicker">Steam</span>
            <h1 class="hero-title">Redirecting to Steam...</h1>
            <p class="hero-text">Authorization is in progress. If the redirect does not start automatically, reload the page and try again.</p>
        </div>
        <div class="hero-panel">
            <div class="hero-stat">
                <span class="hero-stat-label">Status</span>
                <strong>Waiting for Steam OpenID</strong>
            </div>
            <div class="hero-stat">
                <span class="hero-stat-label">Action</span>
                <a class="btn app-button-primary" asp-page="/Profile">Open profile</a>
            </div>
        </div>
    </section>
</div>
