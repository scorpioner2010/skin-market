@page
@model SkinMarket.Pages.MarketModel
@{
    ViewData["Title"] = L["Page_Market_Title"];
}

<div class="market-page py-4">
    <div class="page-header">
        <div>
            <h1>@L["Page_Market_Title"]</h1>
        </div>
        <div class="status-group">
            <form method="get" class="game-switcher" aria-label="@L["Inventory_GameSelector"]">
                <label class="game-switcher-label" for="market-game">@L["Common_Game"]</label>
                <select id="market-game" name="game" class="form-select app-input game-switcher-select" onchange="this.form.submit()">
                    @foreach (var game in Model.SupportedGames.Where(item => item.SupportsInventory))
                    {
                        if (game.Type == Model.CurrentGameType)
                        {
                            <option value="@game.Type" selected>@game.DisplayName</option>
                        }
                        else
                        {
                            <option value="@game.Type">@game.DisplayName</option>
                        }
                    }
                </select>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="app-alert alert-success" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.SuccessMessage)</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert alert-danger" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.ErrorMessage)</div>
    }

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div class="summary-card market-balance-card">
            <span class="market-balance-label">@L["Market_AvailableBalance"]</span>
            <h2>$@Model.CurrentBalance.ToString("0.00")</h2>
        </div>
    }

    @if (Model.GroupedItems.Count == 0)
    {
        <div class="empty-state">
            <h2>@L["Market_Empty_Title"]</h2>
        </div>
    }
    else
    {
        <section class="page-section">
            <div class="section-heading">
                <div>
                    <h2>@L["Market_AvailableItems_Title"]</h2>
                    <p class="section-description">@L["Market_AvailableItems_Summary", Model.CurrentGameDisplayName, Model.GroupedItems.Count, Model.TotalAvailableItemCount]</p>
                </div>
                <div class="market-view-toggle" role="group" aria-label="@L["Market_View"]">
                    <button type="button" class="market-view-button active" data-market-view-button="cards">@L["Common_Cards"]</button>
                    <button type="button" class="market-view-button" data-market-view-button="table">@L["Common_Table"]</button>
                </div>
            </div>
            <div class="card-grid market-card-grid" data-market-view-panel="cards">
                @foreach (var item in Model.GroupedItems)
                {
                    <article class="content-card item-card market-item-card">
                        <div class="market-item-top">
                            <div class="market-item-visual">
                                @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                {
                                    <img src="@item.IconUrl" alt="@item.ItemName" class="item-icon market-item-icon" />
                                }
                                else
                                {
                                    <div class="market-item-icon-fallback" aria-hidden="true">
                                        @((item.ItemName.FirstOrDefault()).ToString().ToUpperInvariant())
                                    </div>
                                }
                            </div>
                            <div class="market-item-copy">
                                <div class="market-item-head">
                                    <div>
                                        <h2 class="card-title market-item-title">@item.ItemName</h2>
                                        @if (!string.IsNullOrWhiteSpace(item.MarketHashName))
                                        {
                                            <p class="card-subtitle market-item-subtitle">@item.MarketHashName</p>
                                        }
                                    </div>
                                    <div class="market-price-block">
                                        <span class="compact-badge market-quantity-badge">@L["Common_QuantityShort"]: @item.Quantity</span>
                                        <span class="market-price-label">@L["Common_Price"]</span>
                                        <p class="price-tag market-price-tag">$@item.Price.ToString("0.00")</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <dl class="detail-list compact market-detail-list">
                            <div class="detail-row market-detail-row">
                                <dt>@L["Common_AssetId"]</dt>
                                <dd class="break-value market-detail-value">@item.AssetId</dd>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.MarketHashName))
                            {
                                <div class="detail-row market-detail-row">
                                    <dt>@L["Common_MarketHash"]</dt>
                                    <dd class="break-value market-detail-value">@item.MarketHashName</dd>
                                </div>
                            }
                        </dl>

                        @if (item.Tradable != true)
                        {
                            <p class="meta-note market-owner-note">@L["Market_TradeProtection_Text"]</p>
                        }
                        else if (!(User.Identity?.IsAuthenticated ?? false))
                        {
                            <div class="action-row market-item-actions">
                                <a class="btn app-button-primary market-action-button" asp-page="/Auth/Login">@L["Common_LoginWithSteam"]</a>
                            </div>
                        }
                        else if (!item.HasBuyableItems)
                        {
                            <p class="meta-note market-owner-note">@L["Market_OwnItemBotInventory_Text"]</p>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Buy" class="action-row market-item-actions" data-trade-blockable-form data-trade-block-message="@L["Market_TradeBlockMessageBuy"]">
                                <input type="hidden" asp-for="PurchaseRequest.GameType" value="@item.GameType" />
                                <input type="hidden" asp-for="PurchaseRequest.AppId" value="@item.AppId" />
                                <input type="hidden" asp-for="PurchaseRequest.ContextId" value="@item.ContextId" />
                                <input type="hidden" asp-for="PurchaseRequest.AssetId" value="@item.AssetId" />
                                <input type="hidden" asp-for="PurchaseRequest.ClassId" value="@item.ClassId" />
                                <input type="hidden" asp-for="PurchaseRequest.InstanceId" value="@item.InstanceId" />
                                <input type="hidden" asp-for="PurchaseRequest.ItemName" value="@item.ItemName" />
                                <input type="hidden" asp-for="PurchaseRequest.MarketHashName" value="@item.MarketHashName" />
                                <button type="submit" class="btn app-button-primary market-action-button">@L["Common_Buy"]</button>
                            </form>
                        }
                    </article>
                }
            </div>
            <div class="market-table-shell" data-market-view-panel="table" hidden>
                <div class="market-table-list">
                    <div class="market-table-row market-table-header">
                        <div class="market-table-cell market-table-item-cell">@L["Common_Item"]</div>
                        <div class="market-table-cell">@L["Common_QuantityShort"]</div>
                        <div class="market-table-cell">@L["Common_Price"]</div>
                        <div class="market-table-cell">@L["Common_Tradable"]</div>
                        <div class="market-table-cell market-table-asset-cell">@L["Common_AssetId"]</div>
                        <div class="market-table-cell market-table-actions-cell">@L["Common_Action"]</div>
                    </div>
                    @foreach (var item in Model.GroupedItems)
                    {
                        <article class="market-table-row">
                            <div class="market-table-cell market-table-item-cell" data-label="@L["Common_Item"]">
                                <div class="market-table-main">
                                    @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                    {
                                        <img src="@item.IconUrl" alt="@item.ItemName" class="inventory-icon" />
                                    }
                                    else
                                    {
                                        <div class="inventory-icon inventory-icon-fallback" aria-hidden="true">
                                            @((item.ItemName.FirstOrDefault()).ToString().ToUpperInvariant())
                                        </div>
                                    }
                                    <div class="market-table-copy">
                                        <h2 class="inventory-item-name">@item.ItemName</h2>
                                        @if (!string.IsNullOrWhiteSpace(item.MarketHashName))
                                        {
                                            <div class="inventory-meta market-table-subtitle">@item.MarketHashName</div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="market-table-cell" data-label="@L["Common_QuantityShort"]">
                                <span class="balance-pill inventory-count-pill">@item.Quantity</span>
                            </div>
                            <div class="market-table-cell" data-label="@L["Common_Price"]">
                                <span class="price-value">$@item.Price.ToString("0.00")</span>
                            </div>
                            <div class="market-table-cell" data-label="@L["Common_Tradable"]">
                                <span class="compact-badge">@((item.Tradable.HasValue ? L[item.Tradable.Value ? "Common_Yes" : "Common_No"] : L["Common_Unknown"]).Value)</span>
                            </div>
                            <div class="market-table-cell market-table-asset-cell" data-label="@L["Common_AssetId"]">
                                <span class="inventory-meta break-value">@item.AssetId</span>
                            </div>
                            <div class="market-table-cell market-table-actions-cell" data-label="@L["Common_Action"]">
                                @if (item.Tradable != true)
                                {
                                    <span class="compact-badge compact-badge-neutral">@UiTextLocalizer.LocalizeStatus(L, "TradeProtected")</span>
                                }
                                else if (!(User.Identity?.IsAuthenticated ?? false))
                                {
                                    <a class="btn app-button-primary market-table-action-button" asp-page="/Auth/Login">@L["Common_LoginWithSteam"]</a>
                                }
                                else if (!item.HasBuyableItems)
                                {
                                    <span class="compact-badge compact-badge-neutral">@L["Market_OwnedByYou"]</span>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Buy" class="market-table-action-form" data-trade-blockable-form data-trade-block-message="@L["Market_TradeBlockMessageBuy"]">
                                        <input type="hidden" name="PurchaseRequest.GameType" value="@item.GameType" />
                                        <input type="hidden" name="PurchaseRequest.AppId" value="@item.AppId" />
                                        <input type="hidden" name="PurchaseRequest.ContextId" value="@item.ContextId" />
                                        <input type="hidden" name="PurchaseRequest.AssetId" value="@item.AssetId" />
                                        <input type="hidden" name="PurchaseRequest.ClassId" value="@item.ClassId" />
                                        <input type="hidden" name="PurchaseRequest.InstanceId" value="@item.InstanceId" />
                                        <input type="hidden" name="PurchaseRequest.ItemName" value="@item.ItemName" />
                                        <input type="hidden" name="PurchaseRequest.MarketHashName" value="@item.MarketHashName" />
                                        <button type="submit" class="btn app-button-primary market-table-action-button">@L["Common_Buy"]</button>
                                    </form>
                                }
                            </div>
                        </article>
                    }
                </div>
            </div>
        </section>
    }
</div>

@section Scripts {
    <script>
        (() => {
            const buttons = Array.from(document.querySelectorAll('[data-market-view-button]'));
            const panels = Array.from(document.querySelectorAll('[data-market-view-panel]'));
            if (buttons.length === 0 || panels.length === 0) {
                return;
            }

            const storageKey = 'skinmarket-market-view';
            const activate = (view) => {
                const target = view === 'table' ? 'table' : 'cards';

                buttons.forEach((button) => {
                    button.classList.toggle('active', button.dataset.marketViewButton === target);
                });

                panels.forEach((panel) => {
                    panel.hidden = panel.dataset.marketViewPanel !== target;
                });
            };

            activate(localStorage.getItem(storageKey) || 'cards');

            buttons.forEach((button) => {
                button.addEventListener('click', () => {
                    const view = button.dataset.marketViewButton || 'cards';
                    localStorage.setItem(storageKey, view);
                    activate(view);
                });
            });
        })();
    </script>
}
