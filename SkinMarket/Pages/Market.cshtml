@page
@model SkinMarket.Pages.MarketModel
@{
    ViewData["Title"] = L["Page_Market_Title"];
}

<div class="market-page py-4">
    <div class="page-header">
        <div>
            <span class="section-kicker">Live Bot Inventory</span>
            <h1>@L["Page_Market_Title"]</h1>
            <p class="page-description market-page-description">Items shown here are pulled directly from the bot inventory, so the market reflects what is actually available right now.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="app-alert alert-success" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.SuccessMessage)</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="app-alert alert-danger" role="alert">@UiTextLocalizer.LocalizeMessage(L, Model.ErrorMessage)</div>
    }

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div class="summary-card market-balance-card">
            <span class="market-balance-label">Available balance</span>
            <h2>$@Model.CurrentBalance.ToString("0.00")</h2>
        </div>
    }

    @if (Model.GroupedItems.Count == 0)
    {
        <div class="empty-state">
            <h2>@L["Market_Empty_Title"]</h2>
        </div>
    }
    else
    {
        <section class="page-section">
            <div class="section-heading">
                <div>
                    <h2>@L["Market_AvailableItems_Title"]</h2>
                    <p class="section-description">@Model.GroupedItems.Count grouped listing(s), @Model.TotalAvailableItemCount total item(s) currently visible from the bot inventory.</p>
                </div>
            </div>
            <div class="card-grid market-card-grid">
                @foreach (var item in Model.GroupedItems)
                {
                    <article class="content-card item-card market-item-card">
                        <div class="market-item-top">
                            <div class="market-item-visual">
                                @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                {
                                    <img src="@item.IconUrl" alt="@item.ItemName" class="item-icon market-item-icon" />
                                }
                                else
                                {
                                    <div class="market-item-icon-fallback" aria-hidden="true">
                                        @((item.ItemName.FirstOrDefault()).ToString().ToUpperInvariant())
                                    </div>
                                }
                            </div>
                            <div class="market-item-copy">
                                <div class="market-item-head">
                                    <div>
                                        <h2 class="card-title market-item-title">@item.ItemName</h2>
                                        @if (!string.IsNullOrWhiteSpace(item.MarketHashName))
                                        {
                                            <p class="card-subtitle market-item-subtitle">@item.MarketHashName</p>
                                        }
                                    </div>
                                    <div class="market-price-block">
                                        <span class="compact-badge market-quantity-badge">Qty: @item.Quantity</span>
                                        <span class="market-price-label">Price</span>
                                        <p class="price-tag market-price-tag">$@item.Price.ToString("0.00")</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <dl class="detail-list compact market-detail-list">
                            <div class="detail-row market-detail-row">
                                <dt>Asset ID</dt>
                                <dd class="break-value market-detail-value">@item.AssetId</dd>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.MarketHashName))
                            {
                                <div class="detail-row market-detail-row">
                                    <dt>Market Hash</dt>
                                    <dd class="break-value market-detail-value">@item.MarketHashName</dd>
                                </div>
                            }
                        </dl>

                        @if (item.Tradable != true)
                        {
                            <p class="meta-note market-owner-note">Trade protection is active. This item will become buyable after Steam unlocks it.</p>
                        }
                        else if (!(User.Identity?.IsAuthenticated ?? false))
                        {
                            <div class="action-row market-item-actions">
                                <a class="btn app-button-primary market-action-button" asp-page="/Auth/Login">@L["Common_LoginWithSteam"]</a>
                            </div>
                        }
                        else if (!item.HasBuyableItems)
                        {
                            <p class="meta-note market-owner-note">Your item is already in the bot inventory.</p>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Buy" class="action-row market-item-actions" data-trade-blockable-form data-trade-block-message="Finish or cancel the active trade offer before buying another item.">
                                <input type="hidden" asp-for="PurchaseRequest.GameType" value="@item.GameType" />
                                <input type="hidden" asp-for="PurchaseRequest.AppId" value="@item.AppId" />
                                <input type="hidden" asp-for="PurchaseRequest.ContextId" value="@item.ContextId" />
                                <input type="hidden" asp-for="PurchaseRequest.AssetId" value="@item.AssetId" />
                                <input type="hidden" asp-for="PurchaseRequest.ClassId" value="@item.ClassId" />
                                <input type="hidden" asp-for="PurchaseRequest.InstanceId" value="@item.InstanceId" />
                                <input type="hidden" asp-for="PurchaseRequest.ItemName" value="@item.ItemName" />
                                <input type="hidden" asp-for="PurchaseRequest.MarketHashName" value="@item.MarketHashName" />
                                <button type="submit" class="btn app-button-primary market-action-button">@L["Common_Buy"]</button>
                            </form>
                        }
                    </article>
                }
            </div>
        </section>
    }

    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <section class="page-section">
            <div class="section-heading">
                <div>
                    <h2>@L["Market_Purchases_Title"]</h2>
                    <p class="section-description">Your latest orders and delivery states.</p>
                </div>
            </div>
            @if (Model.Purchases.Count == 0)
            {
                <div class="empty-state compact">
                    <h3>@L["Market_Purchases_Empty_Title"]</h3>
                </div>
            }
            else
            {
                <div class="stack-grid">
                    @foreach (var item in Model.Purchases)
                    {
                        <article class="content-card history-card" data-trade-flow-row="delivery" data-operation-id="@item.Id" data-asset-id="@item.AssetId">
                            <div class="card-heading">
                                <div>
                                    <h3>@item.ItemName</h3>
                                    <p class="card-subtitle">@string.Format(L["Market_PurchasedFor"].Value, item.Price.ToString("0.00"))</p>
                                </div>
                                <div class="status-group">
                                    <span class="status-badge" data-status="@item.Status">@UiTextLocalizer.LocalizeStatus(L, item.Status)</span>
                                    @if (!string.IsNullOrWhiteSpace(item.DeliveryStatus))
                                    {
                                        <span class="status-badge" data-status="@item.DeliveryStatus" data-trade-flow-status>@UiTextLocalizer.LocalizeStatus(L, item.DeliveryStatus)</span>
                                    }
                                </div>
                            </div>
                            <div class="history-metrics">
                                <span><strong>@L["Market_Purchased"]:</strong> @item.PurchasedAtUtc</span>
                                @if (!string.IsNullOrWhiteSpace(item.DeliveryTradeOfferId))
                                {
                                    <span><strong>@L["Market_DeliveryTradeOfferId"]:</strong> <span class="break-value">@item.DeliveryTradeOfferId</span></span>
                                }
                                @if (item.DeliveredAtUtc.HasValue)
                                {
                                    <span><strong>@L["Market_Delivered"]:</strong> @item.DeliveredAtUtc</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.DeliveryErrorMessage))
                            {
                                <div class="meta-note">@UiTextLocalizer.LocalizeMessage(L, item.DeliveryErrorMessage)</div>
                            }
                            <div class="action-row">
                                @if (item.DeliveryStatus == "DeliveryFailed")
                                {
                                    <form method="post" asp-page-handler="CreateDeliveryTrade">
                                        <input type="hidden" asp-for="MarketPurchaseId" value="@item.Id" />
                                        <button type="submit" class="btn app-button-secondary">@L["Market_CreateDeliveryTrade"]</button>
                                    </form>
                                }
                                else if (item.DeliveryStatus == "PendingDelivery")
                                {
                                    <span class="compact-badge compact-badge-neutral">Waiting for automatic delivery creation</span>
                                }
                                else if (item.DeliveryStatus == "DeliveryTradeCreated" ||
                                         item.DeliveryStatus == "AwaitingBuyerAction" ||
                                         item.DeliveryStatus == "AwaitingBotConfirmation" ||
                                         item.DeliveryStatus == "DeliveryInEscrow")
                                {
                                    <span class="compact-badge compact-badge-neutral">Waiting for Steam delivery sync</span>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</div>
